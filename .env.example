# ============================================================
# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — never commit real secrets.
# ============================================================

# Google Tag Manager container ID (used by BaseLayout)
GTM_ID=GTM-XXXXXXX

# Staging gate: set to "true" only on production, "false" on staging
# When false, <meta name="robots" content="noindex"> is injected + X-Robots-Tag
ALLOW_INDEXING=false

# OpinionSystem API key (transaction immobilier scope)
# Used by scripts/sync-opinionsystem-reviews.mjs at build time
# to fetch per-expert reviews for expert pages.
# Get the current key from DEVELOPER_HANDOVER.md or ask Roy.
OPINIONSYSTEM_API_KEY=your-key-here
