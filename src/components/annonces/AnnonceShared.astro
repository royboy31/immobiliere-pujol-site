---
// Shared TOP block for both live + closed annonce pages.
// Renders: back link, header, gallery, key figures.
// Caller is responsible for the body grid (description/details + side rail) and
// any bottom sections.

interface View {
  titre: string;
  type: 'V' | 'L' | string;
  priceDisplay: string;
  photos: string[];
  adresse?: string;
  codePostal?: string;
  ville?: string;
  quartier?: string;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  etage?: string | number;
  nbEtages?: string | number;
  isClosed: boolean;
}

interface Props {
  view: View;
}

const { view } = Astro.props;

const isLocation = view.type === 'L';
const priceModifier = isLocation ? 'annonce-head__price--location' : '';
const badgeModifier = view.isClosed
  ? 'annonce-head__badge--closed'
  : isLocation
    ? 'annonce-head__badge--location'
    : '';
---

<a href="/annonces/" class="annonce-back">
  <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
    <path d="M21 7 H2 M8 1 L2 7 L8 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  Retour aux annonces
</a>

<header class="annonce-head">
  <div>
    <h1 class="annonce-head__title">{view.titre}</h1>
    <p class="annonce-head__loc">
      {view.adresse && `${view.adresse}, `}{view.codePostal} {view.ville}
      {view.quartier && <> — {view.quartier}</>}
    </p>
  </div>
  <div class="annonce-head__price-block">
    <span class={`annonce-head__badge ${badgeModifier}`}>
      {view.isClosed ? 'Bien clôturé' : (isLocation ? 'Location' : 'Vente')}
    </span>
    {view.priceDisplay && (
      <span class={`annonce-head__price ${priceModifier}`}>{view.priceDisplay}</span>
    )}
  </div>
</header>

{view.photos.length > 0 ? (
  <div class="annonce-gallery">
    <div class="annonce-gallery__main">
      <img src={view.photos[0]} alt={view.titre} id="main-photo" loading="eager" />
    </div>
    <div class="annonce-gallery__side">
      {view.photos[1] && (
        <button class="annonce-gallery__thumb" data-src={view.photos[1]} type="button">
          <img src={view.photos[1]} alt={`${view.titre} – photo 2`} loading="lazy" />
        </button>
      )}
      {view.photos[2] && (
        <button
          class={`annonce-gallery__thumb ${view.photos.length > 3 ? 'annonce-gallery__thumb--more' : ''}`}
          data-src={view.photos[2]}
          data-more={view.photos.length > 3 ? `+${view.photos.length - 3}` : undefined}
          type="button"
        >
          <img src={view.photos[2]} alt={`${view.titre} – photo 3`} loading="lazy" />
        </button>
      )}
    </div>
  </div>
) : (
  <div class="annonce-gallery">
    <div class="annonce-gallery__empty">Pas de photos disponibles</div>
  </div>
)}

<div class="annonce-keyfigs">
  {view.surface && (
    <div class="kf">
      <span class="kf__val"><b>{view.surface}</b> m²</span>
      <span class="kf__lbl">Surface</span>
    </div>
  )}
  {view.nbPieces && (
    <div class="kf">
      <span class="kf__val"><b>{view.nbPieces}</b></span>
      <span class="kf__lbl">Pièce{view.nbPieces > 1 ? 's' : ''}</span>
    </div>
  )}
  {view.nbChambres && (
    <div class="kf">
      <span class="kf__val"><b>{view.nbChambres}</b></span>
      <span class="kf__lbl">Chambre{view.nbChambres > 1 ? 's' : ''}</span>
    </div>
  )}
  {view.etage !== undefined && view.etage !== '' && view.etage !== null && (
    <div class="kf">
      <span class="kf__val"><b>{view.etage}</b>{view.nbEtages ? `/${view.nbEtages}` : ''}</span>
      <span class="kf__lbl">Étage</span>
    </div>
  )}
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.annonce-gallery__thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src;
      const main = document.getElementById('main-photo') as HTMLImageElement | null;
      if (src && main) main.src = src;
    });
  });
</script>
