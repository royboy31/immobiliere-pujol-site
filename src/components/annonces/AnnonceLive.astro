---
import AnnonceHero from './AnnonceHero.astro';
import AnnonceMap from './AnnonceMap.astro';
import ContactForm from './ContactForm.astro';
import DpeDiagram from './DpeDiagram.astro';
import SimilarAnnonces from './SimilarAnnonces.astro';
import Lightbox from './Lightbox.astro';
import ExpertCard from '../experts/ExpertCard.astro';
import type { Expert } from '../../lib/experts';
import type { UbiflowAnnonce } from '../../lib/ubiflow';

interface View {
  titre: string;
  description: string;
  type: 'V' | 'L' | string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  visiteVirtuelle?: string;
  tourEmbedAllowed?: boolean;
  adresse?: string;
  codePostal?: string;
  ville?: string;
  quartier?: string;
  latitude?: number | null;
  longitude?: number | null;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | number;
  nbEtages?: string | number;
  meuble?: number | null;
  typeChauffage?: string;
  cuisine?: string;
  dpeEtiquetteConso?: string;
  dpeEtiquetteGes?: string;
  dpeValeurConso?: string;
  dpeValeurGes?: string;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honoraires?: string | null;
  honorairesEtatDesLieux?: number | null;
  honorairesChargeAcquereur?: boolean;
  isClosed: boolean;
}

interface Props {
  view: View;
  contactName?: string | null;
  contactEmail?: string | null;
  expert?: Expert | null;
  pool?: UbiflowAnnonce[];
  currentSlug?: string;
}

const { view, contactEmail, expert, pool = [], currentSlug = '' } = Astro.props;

const isSale = view.type === 'V';
const hasMeuble = !isSale && (view.meuble === 0 || view.meuble === 1);
const hasEtage = view.etage !== undefined && view.etage !== '' && view.etage !== null;
const hasNbEtages = !isSale && view.nbEtages !== undefined && view.nbEtages !== '' && view.nbEtages !== null;

const hasTechDetails = !!(
  view.nbPieces || view.nbChambres || view.nbSallesDeBain ||
  view.nbWC || view.cuisine || hasEtage || hasNbEtages || hasMeuble || view.typeChauffage
);

// honoraires arrives as a string from D1; legacy rows can carry "Charge acquéreur"
// instead of a number, so parse and only show when numeric.
const honorairesNum = view.honoraires != null ? parseFloat(String(view.honoraires)) : NaN;
const hasHonoraires = Number.isFinite(honorairesNum) && honorairesNum > 0;
const fmtEur = new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
const honorairesFmt = hasHonoraires ? fmtEur.format(honorairesNum) : '';

const etatDesLieuxNum = view.honorairesEtatDesLieux ?? NaN;
const hasEtatDesLieux = Number.isFinite(etatDesLieuxNum) && etatDesLieuxNum > 0;
const etatDesLieuxFmt = hasEtatDesLieux ? fmtEur.format(etatDesLieuxNum) : '';

const hasFinanceDetails =
  (view.type === 'L' && !!(view.loyer || view.loyerCC || view.charges || view.depotGarantie || hasHonoraires || hasEtatDesLieux)) ||
  (view.type === 'V' && !!(view.prix || view.charges || hasHonoraires || view.honorairesChargeAcquereur));
---

<article class="annonce-page">
  <nav class="annonce-nav annonce-nav--floating">
    <a href={isSale ? '/annonces/ventes/' : '/annonces/locations/'} class="annonce-back">
      <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
        <path d="M21 7 H2 M8 1 L2 7 L8 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Retour aux annonces
    </a>
    <div class="annonce-nav__arrows" id="annonceNavArrows"></div>
  </nav>

  <AnnonceHero view={view}>
    <Fragment slot="left-below">
      {view.description && (
        <section class="annonce-desc-block">
          <h2>Description</h2>
          <div class="annonce-desc" set:html={
            view.description
              .replace(/(<br\s*\/?>)\s*/gi, '</p><p>')
              .replace(/\n/g, '</p><p>')
              .replace(/^/, '<p>').replace(/$/, '</p>')
              .replace(/<p>\s*<\/p>/g, '')
          }></div>
        </section>
      )}

      {hasTechDetails && (
        <section class="annonce-desc-block annonce-chars-block">
          <h2>Caractéristiques techniques</h2>
          <dl class="annonce-details-dl">
            {view.nbPieces && <><dt>Pièces</dt><dd>{view.nbPieces}</dd></>}
            {view.nbChambres && <><dt>Chambres</dt><dd>{view.nbChambres}</dd></>}
            {view.nbSallesDeBain && <><dt>Salles de bain</dt><dd>{view.nbSallesDeBain}</dd></>}
            {view.nbWC && <><dt>WC</dt><dd>{view.nbWC}</dd></>}
            {hasEtage && <><dt>Étage</dt><dd>{view.etage}</dd></>}
            {hasNbEtages && <><dt>Nombre d'étage</dt><dd>{view.nbEtages}</dd></>}
            {hasMeuble && <><dt>Meublé</dt><dd>{view.meuble ? 'Oui' : 'Non'}</dd></>}
            {view.cuisine && <><dt>Cuisine</dt><dd>{view.cuisine}</dd></>}
            {view.typeChauffage && <><dt>Chauffage</dt><dd>{view.typeChauffage}</dd></>}
          </dl>
        </section>
      )}

      {hasFinanceDetails && (
        <section class="annonce-desc-block annonce-chars-block">
          <h2>Aspects financiers</h2>
          <dl class="annonce-details-dl">
            {view.type === 'L' && view.loyerCC && <><dt>Loyer charges comprises</dt><dd>{view.loyerCC} €/mois</dd></>}
            {view.type === 'L' && !view.loyerCC && view.loyer && <><dt>Loyer hors charges</dt><dd>{view.loyer} €/mois</dd></>}
            {view.type === 'L' && view.charges && <><dt>dont charges</dt><dd>{view.charges} €/mois</dd></>}
            {view.type === 'L' && hasHonoraires && <><dt>Honoraires d'agence (TTC)</dt><dd>{honorairesFmt} €</dd></>}
            {view.type === 'L' && hasEtatDesLieux && <><dt>Honoraires état des lieux</dt><dd>{etatDesLieuxFmt} €</dd></>}
            {view.type === 'L' && view.depotGarantie && <><dt>Dépôt de garantie</dt><dd>{view.depotGarantie} €</dd></>}
            {view.type === 'V' && view.prix && <><dt>Prix</dt><dd>{new Intl.NumberFormat('fr-FR').format(view.prix)} €</dd></>}
            {view.type === 'V' && view.charges && <><dt>Charges</dt><dd>{view.charges} €/mois</dd></>}
            {view.type === 'V' && hasHonoraires && <><dt>Honoraires d'agence (TTC)</dt><dd>{honorairesFmt} €</dd></>}
            {view.type === 'V' && view.honorairesChargeAcquereur && <><dt>Honoraires</dt><dd>À la charge de l'acquéreur</dd></>}
          </dl>
        </section>
      )}
    </Fragment>

    <ContactForm
      slot="action"
      reference={view.reference}
      titre={view.titre}
      contactEmail={contactEmail}
      type={view.type}
    />

    <Fragment slot="action-below">
      {expert && <ExpertCard expert={expert} showPhone={isSale} />}
      <AnnonceMap
        variant="sidebar"
        adresse={view.adresse}
        codePostal={view.codePostal}
        ville={view.ville}
        quartier={view.quartier}
        latitude={view.latitude}
        longitude={view.longitude}
      />
    </Fragment>
  </AnnonceHero>

  {(view.dpeEtiquetteConso || view.dpeEtiquetteGes) && (
    <section class="annonce-perf">
      <h2 class="annonce-perf__title">Performance <b>énergétique</b></h2>
      <p class="annonce-perf__hint">Cliquez pour agrandir.</p>
      <div class="annonce-perf__grid">
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-diagram-conso"
           data-lightbox-caption="Diagnostic de performance énergétique">
          <span id="dpe-diagram-conso"><DpeDiagram kind="DPE" letter={view.dpeEtiquetteConso} value={view.dpeValeurConso} /></span>
        </a>
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-diagram-ges"
           data-lightbox-caption="Émissions de gaz à effet de serre">
          <span id="dpe-diagram-ges"><DpeDiagram kind="GES" letter={view.dpeEtiquetteGes} value={view.dpeValeurGes} /></span>
        </a>
      </div>
    </section>
  )}

  {pool.length > 0 && (
    <SimilarAnnonces
      pool={pool}
      currentSlug={currentSlug}
      type={view.type}
      codePostal={view.codePostal}
      max={3}
    />
  )}

  <Lightbox />
</article>
