---
import AnnonceHero from './AnnonceHero.astro';
import ContactForm from './ContactForm.astro';
import DpeScale from './DpeScale.astro';
import SimilarAnnonces from './SimilarAnnonces.astro';
import Lightbox from './Lightbox.astro';
import ExpertCard from '../experts/ExpertCard.astro';
import type { Expert } from '../../lib/experts';
import type { UbiflowAnnonce } from '../../lib/ubiflow';

interface View {
  titre: string;
  description: string;
  type: 'V' | 'L' | string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  visiteVirtuelle?: string;
  adresse?: string;
  codePostal?: string;
  ville?: string;
  quartier?: string;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | number;
  nbEtages?: string | number;
  typeChauffage?: string;
  cuisine?: string;
  dpeEtiquetteConso?: string;
  dpeEtiquetteGes?: string;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honorairesChargeAcquereur?: boolean;
  isClosed: boolean;
}

interface Props {
  view: View;
  contactName?: string | null;
  contactPhone?: string | null;
  contactEmail?: string | null;
  expert?: Expert | null;
  pool?: UbiflowAnnonce[];
  currentSlug?: string;
}

const { view, contactPhone, contactEmail, expert, pool = [], currentSlug = '' } = Astro.props;

const hasDetails = !!(
  view.surface || view.nbPieces || view.nbChambres || view.nbSallesDeBain ||
  view.nbWC || view.cuisine || view.typeChauffage || view.loyer || view.loyerCC ||
  view.charges || view.depotGarantie || (view.type === 'V' && view.prix)
);
---

<article class="annonce-page">
  <a href="/annonces/" class="annonce-back annonce-back--floating">
    <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
      <path d="M21 7 H2 M8 1 L2 7 L8 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    Retour aux annonces
  </a>

  <AnnonceHero view={view}>
    <Fragment slot="left-below">
      {view.description && (
        <section class="annonce-desc-block">
          <h2>Description</h2>
          <div class="annonce-desc" set:html={view.description.replace(/\n/g, '<br/>')}></div>
        </section>
      )}

      {hasDetails && (
        <section class="annonce-desc-block annonce-chars-block">
          <h2>Caractéristiques</h2>
          <dl class="annonce-details-dl">
            {view.surface && <><dt>Surface</dt><dd>{view.surface} m²</dd></>}
            {view.nbPieces && <><dt>Pièces</dt><dd>{view.nbPieces}</dd></>}
            {view.nbChambres && <><dt>Chambres</dt><dd>{view.nbChambres}</dd></>}
            {view.nbSallesDeBain && <><dt>Salles de bain</dt><dd>{view.nbSallesDeBain}</dd></>}
            {view.nbWC && <><dt>WC</dt><dd>{view.nbWC}</dd></>}
            {view.cuisine && <><dt>Cuisine</dt><dd>{view.cuisine}</dd></>}
            {view.typeChauffage && <><dt>Chauffage</dt><dd>{view.typeChauffage}</dd></>}
            {view.type === 'L' && view.loyer && <><dt>Loyer HC</dt><dd>{view.loyer} €</dd></>}
            {view.type === 'L' && view.loyerCC && <><dt>Loyer CC</dt><dd>{view.loyerCC} €/mois</dd></>}
            {view.type === 'L' && view.charges && <><dt>Charges</dt><dd>{view.charges} €/mois</dd></>}
            {view.type === 'L' && view.depotGarantie && <><dt>Dépôt de garantie</dt><dd>{view.depotGarantie} €</dd></>}
            {view.type === 'V' && view.prix && <><dt>Prix</dt><dd>{new Intl.NumberFormat('fr-FR').format(view.prix)} €</dd></>}
            {view.type === 'V' && view.honorairesChargeAcquereur && <><dt>Honoraires</dt><dd>À la charge de l'acquéreur</dd></>}
          </dl>
        </section>
      )}
    </Fragment>

    <ContactForm
      slot="action"
      reference={view.reference}
      titre={view.titre}
      contactEmail={contactEmail}
      contactPhone={contactPhone}
      type={view.type}
    />

    {expert && <ExpertCard slot="action-below" expert={expert} />}
  </AnnonceHero>

  {(view.dpeEtiquetteConso || view.dpeEtiquetteGes) && (
    <section class="annonce-perf">
      <h2 class="annonce-perf__title">Performance <b>énergétique</b></h2>
      <p class="annonce-perf__hint">Cliquez pour agrandir.</p>
      <div class="annonce-perf__grid">
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-scale-conso"
           data-lightbox-caption="Diagnostic de performance énergétique"
           aria-label="Agrandir le DPE">
          <span id="dpe-scale-conso"><DpeScale kind="DPE" letter={view.dpeEtiquetteConso} /></span>
          <span class="annonce-perf__expand" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M3 9 V3 H9 M21 9 V3 H15 M3 15 V21 H9 M21 15 V21 H15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
            </svg>
          </span>
        </a>
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-scale-ges"
           data-lightbox-caption="Émissions de gaz à effet de serre"
           aria-label="Agrandir le GES">
          <span id="dpe-scale-ges"><DpeScale kind="GES" letter={view.dpeEtiquetteGes} /></span>
          <span class="annonce-perf__expand" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M3 9 V3 H9 M21 9 V3 H15 M3 15 V21 H9 M21 15 V21 H15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
            </svg>
          </span>
        </a>
      </div>
    </section>
  )}

  {pool.length > 0 && (
    <SimilarAnnonces
      pool={pool}
      currentSlug={currentSlug}
      type={view.type}
      codePostal={view.codePostal}
      max={3}
    />
  )}

  <Lightbox />
</article>
