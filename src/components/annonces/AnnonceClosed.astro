---
import AnnonceHero from './AnnonceHero.astro';
import AnnonceMap from './AnnonceMap.astro';
import DpeDiagram from './DpeDiagram.astro';
import SimilarAnnonces from './SimilarAnnonces.astro';
import Lightbox from './Lightbox.astro';
import ExpertCard from '../experts/ExpertCard.astro';
import type { Expert } from '../../lib/experts';
import type { ClosedAnnonceRelated } from '../../lib/closed-annonces';
import type { UbiflowAnnonce } from '../../lib/ubiflow';

interface View {
  titre: string;
  description: string;
  type: 'V' | 'L' | string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  visiteVirtuelle?: string;
  adresse?: string;
  codePostal?: string;
  ville?: string;
  quartier?: string;
  latitude?: number | null;
  longitude?: number | null;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | number;
  nbEtages?: string | number;
  typeChauffage?: string;
  cuisine?: string;
  dpeEtiquetteConso?: string;
  dpeEtiquetteGes?: string;
  dpeValeurConso?: string;
  dpeValeurGes?: string;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honorairesChargeAcquereur?: boolean;
  isClosed: boolean;
}

interface Props {
  view: View;
  expert?: Expert | null;
  related?: ClosedAnnonceRelated[];
  pool?: UbiflowAnnonce[];
  currentSlug?: string;
}

const { view, expert, related = [], pool = [], currentSlug = '' } = Astro.props;
const isLocation = view.type === 'L';
const similarHref = isLocation ? '/annonces/locations/' : '/annonces/ventes/';
const similarLabel = isLocation
  ? 'VOIR LES LOCATIONS DISPONIBLES'
  : 'VOIR LES VENTES DISPONIBLES';

const services = isLocation
  ? [
      { href: '/service-immobilier/gestion-locative/', icon: '/images/home/svc-gestion.svg', label: 'Gestion Locative à', city: 'Marseille' },
      { href: '/services/estimation-loyer/', icon: '/images/home/svc-syndic.svg', label: 'Estimer un loyer', city: '' },
      { href: '/contact-immobiliere-pujol/', icon: '/images/home/svc-vendre.svg', label: 'Décrire votre projet', city: 'Marseille' },
    ]
  : [
      { href: '/service-immobilier/vendre/', icon: '/images/home/svc-vendre.svg', label: 'Vendre', city: 'Marseille' },
      { href: '/services/estimation-prix-de-vente/', icon: '/images/home/svc-syndic.svg', label: 'Estimer un bien', city: '' },
      { href: '/service-immobilier/syndic-de-copropriete-a-marseille/', icon: '/images/home/svc-syndic.svg', label: 'Syndic de copropriété à', city: 'Marseille' },
    ];

const relatedCards = (related ?? []).slice(0, 3).map((r) => ({
  href: `/annonces/${r.slug}/`,
  isVente: r.type === 'V',
  title: r.title,
  price: r.prix
    ? r.type === 'V'
      ? `${new Intl.NumberFormat('fr-FR').format(r.prix)} €`
      : `${new Intl.NumberFormat('fr-FR').format(r.prix)} €/mois`
    : '',
  cp: r.cp,
}));

const hasDetails = !!(
  view.surface || view.nbPieces || view.nbChambres || view.nbSallesDeBain ||
  view.nbWC || view.cuisine || view.typeChauffage || view.loyer || view.loyerCC ||
  view.charges || view.depotGarantie || (view.type === 'V' && view.prix)
);
---

<div class="annonce-closed-banner">
  <strong>Cette annonce n'est plus disponible.</strong>
  <a href="/annonces/">Voir nos annonces actuelles →</a>
</div>

<article class="annonce-page">
  <a href="/annonces/" class="annonce-back annonce-back--floating">
    <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
      <path d="M21 7 H2 M8 1 L2 7 L8 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    Retour aux annonces
  </a>

  <AnnonceHero view={view}>
    <Fragment slot="left-below">
      {view.description && (
        <section class="annonce-desc-block">
          <h2>Description</h2>
          <div class="annonce-desc" set:html={view.description.replace(/\n/g, '<br/>')}></div>
        </section>
      )}

      {hasDetails && (
        <section class="annonce-desc-block annonce-chars-block">
          <h2>Caractéristiques</h2>
          <dl class="annonce-details-dl">
            {view.surface && <><dt>Surface</dt><dd>{view.surface} m²</dd></>}
            {view.nbPieces && <><dt>Pièces</dt><dd>{view.nbPieces}</dd></>}
            {view.nbChambres && <><dt>Chambres</dt><dd>{view.nbChambres}</dd></>}
            {view.nbSallesDeBain && <><dt>Salles de bain</dt><dd>{view.nbSallesDeBain}</dd></>}
            {view.nbWC && <><dt>WC</dt><dd>{view.nbWC}</dd></>}
            {view.cuisine && <><dt>Cuisine</dt><dd>{view.cuisine}</dd></>}
            {view.typeChauffage && <><dt>Chauffage</dt><dd>{view.typeChauffage}</dd></>}
            {view.type === 'L' && view.loyerCC && <><dt>Loyer CC</dt><dd>{view.loyerCC} €/mois</dd></>}
            {view.type === 'L' && view.charges && <><dt>Charges</dt><dd>{view.charges} €/mois</dd></>}
            {view.type === 'V' && view.prix && <><dt>Prix</dt><dd>{new Intl.NumberFormat('fr-FR').format(view.prix)} €</dd></>}
          </dl>
        </section>
      )}
    </Fragment>

    <div slot="action" class="annonce-cta-card annonce-cta-card--closed">
      <h3>Ce bien <b>a trouvé preneur</b></h3>
      <p>Confiez-nous vos critères. Nous vous préviendrons dès qu'un bien équivalent rejoint notre catalogue.</p>
      <div class="annonce-cta-card__btns">
        <a href={similarHref} class="btn-pill btn-pill--white">{similarLabel}</a>
        <a href="/contact-immobiliere-pujol/" class="btn-pill btn-pill--white-outline">ÊTRE PRÉVENU</a>
      </div>
      <div class="annonce-cta-card__ref">Référence : {view.reference}</div>
    </div>

    <Fragment slot="action-below">
      {expert && <ExpertCard expert={expert} />}
      <AnnonceMap
        variant="sidebar"
        adresse={view.adresse}
        codePostal={view.codePostal}
        ville={view.ville}
        quartier={view.quartier}
        latitude={view.latitude}
        longitude={view.longitude}
      />
    </Fragment>
  </AnnonceHero>

  <section class="annonce-services">
    <h3 class="annonce-services__title">Découvrez aussi <b>nos services</b></h3>
    <div class="annonce-services__row">
      {services.map((s) => (
        <a class="annonce-svc-card" href={s.href}>
          <span class="ic"><img src={s.icon} alt="" /></span>
          <span class="lbl">
            {s.label}
            {s.city && <span class="city">{s.city}</span>}
          </span>
          <span class="arr">
            <svg width="22" height="14" viewBox="0 0 22 14" fill="none">
              <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  {(view.dpeEtiquetteConso || view.dpeEtiquetteGes) && (
    <section class="annonce-perf">
      <h2 class="annonce-perf__title">Performance <b>énergétique</b></h2>
      <p class="annonce-perf__hint">Cliquez pour agrandir.</p>
      <div class="annonce-perf__grid">
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-diagram-conso"
           data-lightbox-caption="Diagnostic de performance énergétique">
          <span id="dpe-diagram-conso"><DpeDiagram kind="DPE" letter={view.dpeEtiquetteConso} value={view.dpeValeurConso} /></span>
        </a>
        <a class="annonce-perf__cell"
           href="#"
           data-lightbox-group="dpe"
           data-lightbox-html="#dpe-diagram-ges"
           data-lightbox-caption="Émissions de gaz à effet de serre">
          <span id="dpe-diagram-ges"><DpeDiagram kind="GES" letter={view.dpeEtiquetteGes} value={view.dpeValeurGes} /></span>
        </a>
      </div>
    </section>
  )}

  {pool.length > 0 && (
    <SimilarAnnonces
      pool={pool}
      currentSlug={currentSlug}
      type={view.type}
      codePostal={view.codePostal}
      max={3}
    />
  )}

  {relatedCards.length > 0 && pool.length === 0 && (
    <section class="annonce-related">
      <h2 class="annonce-related__title">
        Autres biens dans le <b>{view.codePostal || 'secteur'}</b>
      </h2>
      <div class="annonce-related__grid">
        {relatedCards.map((c) => (
          <a class={`listing-card ${c.isVente ? '' : 'listing-card--location'}`} href={c.href}>
            <div class="photo" style="background:#d9d9d9">
              <span class={`badge ${c.isVente ? 'badge--vente' : ''}`}>{c.isVente ? 'VENTE' : 'LOCATION'}</span>
            </div>
            <div class="body">
              <div class="title">{c.title}</div>
              {c.price && <div class="price">{c.price}</div>}
              {c.cp && <div class="loc"><span>{c.cp} Marseille</span></div>}
            </div>
          </a>
        ))}
      </div>
      <div class="annonce-related__cta">
        <a href={similarHref} class={`btn-pill ${isLocation ? 'btn-pill--olive' : 'btn-pill--orange'}`}>
          {similarLabel}
        </a>
      </div>
    </section>
  )}

  <Lightbox />
</article>
