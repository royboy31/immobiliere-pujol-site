---
// Primary navigation — mirrors the live site (immobiliere-pujol.fr) menu.
const navItems = [
  {
    label: 'Mise en location',
    href: '/service-immobilier/mettre-en-location/',
    children: [
      { label: 'Nos conseils et services en location', href: '/service-immobilier/mettre-en-location/' },
      { label: 'Estimation de loyer', href: '/service-immobilier/mettre-en-location/#form' },
      { label: 'Nos annonces de location', href: '/annonces/location/' },
    ],
  },
  {
    label: 'Gestion locative',
    href: '/service-immobilier/gestion-locative/',
    children: [
      { label: 'Nos conseils et services en gestion', href: '/service-immobilier/gestion-locative/' },
      { label: 'Etude du marché locatif à Marseille', href: '/services/etude-sur-le-marche-de-la-location-a-marseille/' },
      { label: 'Obtenir un devis de Gestion Locative', href: '/service/devis-gestion-locative-marseille/' },
      { label: 'Contacter notre expert en gestion locative', href: '/services/contacter-un-conseiller-en-gestion-locative/' },
    ],
  },
  {
    label: 'Vendre',
    href: '/service-immobilier/vendre/',
    children: [
      { label: 'Nos conseils et services pour vendre', href: '/service-immobilier/vendre/' },
      { label: 'Estimation de prix de vente', href: '/estimez-le-prix-de-vente-de-votre-bien-en-2mn/' },
      { label: 'Nos annonces en vente', href: '/annonces/vente/' },
    ],
  },
  {
    label: 'Syndic',
    href: '/service-immobilier/syndic-de-copropriete-a-marseille/',
    children: [
      { label: 'Nos conseils et services en syndic', href: '/service-immobilier/syndic-de-copropriete-a-marseille/' },
      { label: 'Obtenir un devis en Syndic', href: '/service-immobilier/syndic-de-copropriete-a-marseille/#form' },
    ],
  },
  {
    label: "L'agence",
    href: '/service-immobilier/agence-immobiliere-pujol/',
    children: [
      { label: 'Qui sommes-nous?', href: '/service-immobilier/agence-immobiliere-pujol/#une-relation-personnalisee' },
      { label: 'Les avis de nos clients', href: '/services/avis-clients-immobiliere-pujol-marseille/' },
      { label: 'Immobilière Pujol in english', href: '/service-immobilier/agence-immobiliere-pujol/#limmobiliere-pujol-en-anglais' },
      { label: 'Candidater chez nous', href: '/service-immobilier/agence-immobiliere-pujol/#candidature-immobilier-marseille' },
    ],
  },
  {
    label: 'Le blog',
    href: '/blog-immobilier-marseille/',
  },
];
---

<div class="site-topbar">
  <div class="rating">
    <img class="g" src="/images/home/google-icon.png" alt="Google" />
    <div style="display:flex;flex-direction:column;line-height:1.05;gap:1px">
      <div style="display:flex;align-items:center;gap:6px">
        <span class="score">4.7</span>
        <img class="stars" src="/images/home/google-stars.png" alt="" />
      </div>
      <span class="reviews">2008 avis Google vérifiés</span>
    </div>
  </div>
  <div class="right">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.6" />
      <path d="M4 21 C 4 16, 8 14, 12 14 C 16 14, 20 16, 20 21" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" />
    </svg>
    <a href="/mon-compte/" class="conn">CONNEXION</a>
  </div>
</div>

<header class="site-header" id="siteHeader">
  <a class="logo" href="/" aria-label="Immobilière Pujol - Accueil">
    <img src="/images/home/pujol-logo.png" alt="Immobilière Pujol" />
  </a>
  <ul class="menu" id="primaryMenu" aria-label="Navigation principale">
    {navItems.map((item) => (
      <li class="item">
        <a href={item.href}>
          {item.label}
          {item.children && (
            <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M1 1 L5 5 L9 1" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
            </svg>
          )}
        </a>
        {item.children && (
          <ul class="submenu">
            {item.children.map((child) => (
              <li><a href={child.href}>{child.label}</a></li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
  <div class="icons">
    <a href="/contact-immobiliere-pujol/" aria-label="Nous contacter">
      <img class="ic-mail" src="/images/home/Vector-mail.svg" alt="" />
    </a>
    <button type="button" aria-label="Rechercher">
      <img class="ic-search" src="/images/home/Vector-search.svg" alt="" />
    </button>
    <button type="button" class="nav-burger" id="navBurger" aria-controls="primaryMenu" aria-expanded="false" aria-label="Ouvrir le menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  (function () {
    const header = document.getElementById('siteHeader');
    const burger = document.getElementById('navBurger');
    if (!header || !burger) return;

    burger.addEventListener('click', () => {
      const open = header.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    });

    // Mobile-only: tapping a parent item with children toggles its submenu
    // (instead of immediately navigating). The link still works on desktop.
    header.querySelectorAll<HTMLLIElement>('.menu .item').forEach((item) => {
      const link = item.querySelector<HTMLAnchorElement>(':scope > a');
      const sub = item.querySelector<HTMLUListElement>(':scope > .submenu');
      if (!link || !sub) return;
      link.addEventListener('click', (e) => {
        if (window.matchMedia('(max-width: 768px)').matches) {
          e.preventDefault();
          item.classList.toggle('is-open');
        }
      });
    });
  })();
</script>
