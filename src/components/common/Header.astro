---
// Navigation structure from WordPress menu export
const navItems = [
  {
    label: 'Mise en location',
    href: '/service-immobilier/mettre-en-location/',
    children: [
      { label: 'Nos conseils et services en location', href: '/services/nos-conseils-en-location/' },
      { label: 'Estimation de loyer', href: '/services/estimation-de-loyer/' },
      { label: 'Nos annonces de location', href: '/annonces/locations/' },
    ],
  },
  {
    label: 'Gestion locative',
    href: '/service-immobilier/gestion-locative/',
    children: [
      { label: 'Nos conseils et services en gestion', href: '/services/conseils-gestion-locative/' },
      { label: 'Etude du marché locatif à Marseille', href: '/services/etude-marche-locatif/' },
      { label: 'Obtenir un devis de Gestion Locative', href: '/services/devis-gestion-locative-marseille/' },
      { label: 'Contacter notre expert en gestion locative', href: '/services/contacter-un-conseiller-en-gestion-locative/' },
    ],
  },
  {
    label: 'Vendre',
    href: '/service-immobilier/vendre/',
    children: [
      { label: 'Nos conseils et services pour vendre', href: '/services/conseils-pour-vendre/' },
      { label: 'Estimation de prix de vente', href: '/services/estimation-prix-de-vente/' },
      { label: 'Nos annonces en vente', href: '/annonces/ventes/' },
    ],
  },
  {
    label: 'Syndic',
    href: '/service-immobilier/syndic-de-copropriete-a-marseille/',
    children: [
      { label: 'Nos conseils et services en syndic', href: '/services/conseils-syndic/' },
      { label: 'Obtenir un devis en Syndic', href: '/services/devis-syndic/' },
    ],
  },
  {
    label: "L'agence",
    href: '/service-immobilier/agence-immobiliere-pujol/',
    children: [
      { label: 'Qui sommes-nous?', href: '/services/pourquoi-nous-faisons-ce-metier/' },
      { label: 'Les avis de nos clients', href: '/services/avis-clients/' },
      { label: 'Immobilière Pujol in english', href: '/services/immobiliere-pujol-in-english/' },
      { label: 'Candidater chez nous', href: '/services/candidater/' },
    ],
  },
  {
    label: 'Le blog',
    href: '/blog/',
  },
];
---

<div class="site-topbar">
  <div class="rating">
    <img class="g" src="/images/home/google-icon.png" alt="Google" />
    <div style="display:flex;flex-direction:column;line-height:1.05;gap:1px">
      <div style="display:flex;align-items:center;gap:6px">
        <span class="score">4.7</span>
        <img class="stars" src="/images/home/google-stars.png" alt="" />
      </div>
      <span class="reviews">2008 avis Google vérifiés</span>
    </div>
  </div>
  <div class="right">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.6" />
      <path d="M4 21 C 4 16, 8 14, 12 14 C 16 14, 20 16, 20 21" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" />
    </svg>
    <a href="/mon-compte/" class="conn">CONNEXION</a>
  </div>
</div>

<header class="site-header">
  <a class="logo" href="/" aria-label="Immobilière Pujol - Accueil">
    <img src="/images/home/pujol-logo.png" alt="Immobilière Pujol" />
  </a>
  <ul class="menu" aria-label="Navigation principale">
    {navItems.map((item) => (
      <li class="item">
        <a href={item.href}>
          {item.label}
          {item.children && (
            <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M1 1 L5 5 L9 1" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
            </svg>
          )}
        </a>
        {item.children && (
          <ul class="submenu">
            {item.children.map((child) => (
              <li><a href={child.href}>{child.label}</a></li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
  <div class="icons">
    <a href="/contact-immobiliere-pujol/" aria-label="Nous contacter">
      <img class="ic-mail" src="/images/home/Vector-mail.svg" alt="" />
    </a>
    <button type="button" aria-label="Rechercher">
      <img class="ic-search" src="/images/home/Vector-search.svg" alt="" />
    </button>
  </div>
</header>
