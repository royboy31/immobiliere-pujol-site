---
const quickLinks = [
  { label: 'Voir nos T2 à louer', href: '/biens/louer/appartement-2-pieces/' },
  { label: 'Voir nos T3 à louer', href: '/biens/louer/appartement-3-pieces/' },
  { label: 'Voir nos T4 et plus à louer', href: '/biens/louer/appartement-4-pieces/' },
];

const legalLinks = [
  { label: 'Voir nos parking/box à louer', href: '/biens/louer/parking-box/' },
  { label: 'Voir les bureaux/locaux à louer', href: '/biens/louer/bureaux/' },
  { label: 'Mentions légales et nos tarifs', href: '/agence-immobiliere-marseille-gestion-locative-et-syndic/mentions-legales-immobiliere-pujol/' },
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite/' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="top">
    <div class="col">
      <a class="logo-foot" href="/" aria-label="Immobilière Pujol">
        <img src="/images/home/pujol-logo-white.png" alt="Immobilière Pujol" />
      </a>
      <div class="socials">
        <a class="soc" href="https://www.facebook.com/location.appartement.marseille" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.25-1.5 1.55-1.5H17V4.6c-.27-.04-1.2-.12-2.27-.12-2.25 0-3.78 1.37-3.78 3.9v2.18H8.25V13.7H10.95V22h2.55z" />
          </svg>
        </a>
        <a class="soc" href="https://www.youtube.com/channel/UCqKIrOqKql-5A7sUsGuIphA" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.6 7.2a2.5 2.5 0 0 0-1.76-1.77C18.27 5 12 5 12 5s-6.27 0-7.84.43A2.5 2.5 0 0 0 2.4 7.2C2 8.77 2 12 2 12s0 3.23.4 4.8a2.5 2.5 0 0 0 1.76 1.77C5.73 19 12 19 12 19s6.27 0 7.84-.43a2.5 2.5 0 0 0 1.76-1.77C22 15.23 22 12 22 12s0-3.23-.4-4.8zM10 15.2V8.8l5.5 3.2-5.5 3.2z" />
          </svg>
        </a>
        <a class="soc" href="https://twitter.com/stephanepujol" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.53 3H20.5l-6.5 7.43L21.7 21h-6.04l-4.74-6.2L5.5 21H2.53l6.96-7.96L2 3h6.2l4.28 5.66L17.53 3zm-1.06 16.2h1.66L7.6 4.7H5.83L16.47 19.2z" />
          </svg>
        </a>
        <a class="soc" href="https://www.instagram.com/immobiliere_pujol/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7" />
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7" />
            <circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" />
          </svg>
        </a>
      </div>
    </div>
    <div class="col">
      <h4>ACCÈS RAPIDE</h4>
      <ul>
        {quickLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="col">
      <h4>LÉGALES ET POLITIQUES</h4>
      <ul>
        {legalLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="bot">© {year}. immobiliere-pujol. All rights reserved | Design by <a href="https://perelweb.be" target="_blank" rel="noopener">Perel Web Studio</a></div>
</footer>
