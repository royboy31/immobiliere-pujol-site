---
const services = [
  { label: 'Mise en location', href: '/service-immobilier/mettre-en-location/' },
  { label: 'Gestion locative', href: '/service-immobilier/gestion-locative/' },
  { label: 'Vendre votre bien', href: '/service-immobilier/vendre/' },
  { label: 'Syndic de copropriété', href: '/service-immobilier/syndic-de-copropriete-a-marseille/' },
  { label: "Acheter à Marseille", href: '/annonces/ventes/' },
];

const annonces = [
  { label: 'Toutes nos annonces', href: '/annonces/' },
  { label: 'Annonces en vente', href: '/annonces/ventes/' },
  { label: 'Annonces en location', href: '/annonces/locations/' },
  { label: 'Estimation de prix de vente', href: '/estimez-le-prix-de-vente-de-votre-bien-en-2mn/' },
  { label: 'Estimation de loyer', href: '/service-immobilier/mettre-en-location/#form' },
  { label: 'Devis Gestion Locative', href: '/services/devis-gestion-locative-marseille/' },
];

const agence = [
  { label: "L'agence Immobilière Pujol", href: '/service-immobilier/agence-immobiliere-pujol/' },
  { label: 'La team Pujol', href: '/services/la-team-pujol/' },
  { label: 'Nos valeurs', href: '/services/pourquoi-nous-faisons-ce-metier/' },
  { label: 'Avis clients', href: '/services/avis-clients-immobiliere-pujol-marseille/' },
  { label: 'Le blog', href: '/blog-immobilier-marseille/' },
  { label: 'Candidater chez nous', href: '/service-immobilier/agence-immobiliere-pujol/#candidature-immobilier-marseille' },
];

const contact = {
  address: '7 rue du Docteur Fiolle, 13006 Marseille',
  mapHref: 'https://maps.google.com/?q=Immobili%C3%A8re+Pujol+7+rue+du+Docteur+Fiolle+13006+Marseille',
  contactHref: '/contact-immobiliere-pujol/',
  hours: 'Lun – Ven : 9h – 12h / 14h – 18h',
};

const legal = [
  { label: 'Mentions légales et tarifs', href: '/agence-immobiliere-marseille-gestion-locative-et-syndic/mentions-legales-immobiliere-pujol/' },
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite/' },
  { label: 'Plan du site', href: '/sitemap_index.xml' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="top">
    <div class="col col--brand">
      <a class="logo-foot" href="/" aria-label="Immobilière Pujol">
        <img src="/images/home/pujol-logo-white.png" alt="Immobilière Pujol" />
      </a>
      <p class="brand-pitch">
        Agence immobilière indépendante à Marseille depuis 2002. Vente, location, gestion locative et syndic de copropriété — guidés par la qualité du service et la confiance.
      </p>
      <div class="socials">
        <a class="soc" href="https://www.youtube.com/channel/UCqKIrOqKql-5A7sUsGuIphA" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.6 7.2a2.5 2.5 0 0 0-1.76-1.77C18.27 5 12 5 12 5s-6.27 0-7.84.43A2.5 2.5 0 0 0 2.4 7.2C2 8.77 2 12 2 12s0 3.23.4 4.8a2.5 2.5 0 0 0 1.76 1.77C5.73 19 12 19 12 19s6.27 0 7.84-.43a2.5 2.5 0 0 0 1.76-1.77C22 15.23 22 12 22 12s0-3.23-.4-4.8zM10 15.2V8.8l5.5 3.2-5.5 3.2z" />
          </svg>
        </a>
        <a class="soc" href="https://www.instagram.com/immobiliere_pujol/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7" />
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7" />
            <circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" />
          </svg>
        </a>
        <a class="soc" href="https://www.facebook.com/immobilierepujol/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.25-1.5 1.55-1.5H17V4.6c-.27-.04-1.2-.12-2.27-.12-2.25 0-3.78 1.37-3.78 3.9v2.18H8.25V13.7H10.95V22h2.55z" />
          </svg>
        </a>
        <a class="soc" href="https://www.linkedin.com/company/immobiliere-pujol/?originalSubdomain=fr" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.66 0h4.37v1.92h.06c.61-1.15 2.1-2.36 4.32-2.36 4.62 0 5.47 3.04 5.47 6.99V22h-4.56v-6.2c0-1.48-.03-3.39-2.06-3.39-2.07 0-2.39 1.61-2.39 3.28V22H7.88V8z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="col">
      <h3>Nos services</h3>
      <ul>
        {services.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="col">
      <h3>Annonces & estimation</h3>
      <ul>
        {annonces.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="col">
      <h3>L'agence</h3>
      <ul>
        {agence.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="col col--contact">
      <h3>Nous contacter</h3>
      <ul class="contact-list">
        <li>
          <span class="ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M12 21s-7-7.5-7-12a7 7 0 0 1 14 0c0 4.5-7 12-7 12z" stroke="currentColor" stroke-width="1.6" />
              <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6" />
            </svg>
          </span>
          <a href={contact.mapHref} target="_blank" rel="noopener noreferrer">{contact.address}</a>
        </li>
        <li>
          <span class="ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" />
              <path d="M12 7 V12 L15 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
          </span>
          <span>{contact.hours}</span>
        </li>
      </ul>
      <a class="contact-cta" href={contact.contactHref}>
        Nous écrire
        <svg width="18" height="12" viewBox="0 0 22 14" fill="none" aria-hidden="true">
          <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  <div class="bot">
    <div class="bot__copy">© {year} Immobilière Pujol — Marseille. Tous droits réservés.</div>
    <ul class="bot__legal">
      {legal.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
    <div class="bot__credit">Design by <a href="https://perelweb.be" target="_blank" rel="noopener">Perel Web Studio</a></div>
  </div>
</footer>
