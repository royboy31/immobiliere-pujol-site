---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { buildWebSite } from '../lib/schemas';
import { fetchGoogleReviews } from '../lib/google-reviews';

// ---------- SEO from CMS page entry ----------
const pageEntry = await getEntry('pages', 'home');
const seoTitle =
  pageEntry?.data.seoTitle ||
  "Immobilière Pujol – L'agence immobilière la plus recommandée par ses clients";
const seoDescription = pageEntry?.data.seoDescription || '';

// ---------- LISTINGS ----------
const allAnnonces = await getCollection('annonces', ({ data }) =>
  data.status === 'publish' && Array.isArray(data.photos) && data.photos.length > 0
);
allAnnonces.sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));

const ventes = allAnnonces.filter((a) => a.data.typeAnnonce === 'V').slice(0, 8);
const locations = allAnnonces.filter((a) => a.data.typeAnnonce === 'L').slice(0, 8);

// Build a display card from a raw annonce.
function fmtPrice(n?: number) {
  if (n == null) return '';
  return new Intl.NumberFormat('fr-FR', { maximumFractionDigits: 0 }).format(n);
}
function buildCard(a: typeof allAnnonces[number]) {
  const d = a.data;
  const isVente = d.typeAnnonce === 'V';
  const photo = (d.photos || [])[0] || '';
  const title =
    (d.descriptif && d.descriptif.replace(/<[^>]+>/g, '').trim().slice(0, 90)) ||
    d.libelle ||
    d.title ||
    `${d.typeBien || 'Bien'} ${d.nbPieces ? 'T' + d.nbPieces : ''}`.trim();
  const price = isVente
    ? `${fmtPrice(d.prix)} €`
    : `${fmtPrice(d.loyerCC ?? d.prix)} €/mois`;
  const pills: string[] = [];
  if (d.nbPieces) pills.push(`T${d.nbPieces}`);
  if (d.surface) pills.push(`${Math.round(d.surface)} m²`);
  if (d.nbPieces) pills.push(`${d.nbPieces} pièces`);
  // Location: prefer quartier + codePostal + ville, fall back to parsing adresse.
  let quartier = d.quartier || '';
  let cpVille = '';
  if (d.codePostal || d.ville) {
    cpVille = `${d.codePostal || ''} ${d.ville || ''}`.trim();
  } else if (d.adresse) {
    const m = d.adresse.match(/(\d{5})[, ]+([^,]+)/);
    if (m) cpVille = `${m[1]} ${m[2].trim()}`;
  }
  return {
    href: `/annonces/${a.id}/`,
    photo,
    isVente,
    title,
    price,
    pills,
    quartier,
    cpVille,
  };
}
const venteCards = ventes.map(buildCard);
const locationCards = locations.map(buildCard);

// ---------- EXPERTS ----------
// Hard-coded from the Claude Design handoff (expert1–4.png have the
// olive / orange / navy circle backgrounds baked in). Caroline Pujol links
// to her real profile; the others link to the experts list page.
const expertsBase = [
  {
    href: '/experts/',
    photo: '/images/home/expert1.png',
    first: 'Julia',
    last: 'Lauron',
    role: 'Ventes de Biens Immobiliers',
  },
  {
    href: '/experts/',
    photo: '/images/home/expert2.png',
    first: 'Gaelle',
    last: 'Lapert',
    role: 'Commerciale en gestion locative',
  },
  {
    href: '/experts/caroline-pujol/',
    photo: '/images/home/expert3.png',
    first: 'Caroline',
    last: 'Pujol',
    role: 'Vente, rénovation et gestion de biens immobiliers à Marseille',
  },
  {
    href: '/experts/',
    photo: '/images/home/expert4.png',
    first: 'Gaelle',
    last: 'Lapert',
    role: 'Commerciale en gestion locative',
  },
];
// Repeat the 4 experts so the carousel has cards to scroll one-by-one.
const experts = [...expertsBase, ...expertsBase, ...expertsBase];

// ---------- ARTICLES ----------
const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => a.data.featuredImage && a.data.date)
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''))
  .slice(0, 12)
  .map((a) => ({
    href: `/blog/${a.id}/`,
    img: a.data.featuredImage!,
    date: a.data.date!,
    title: a.data.title,
    excerpt: (a.data.excerpt || '').replace(/<[^>]+>/g, '').slice(0, 120),
  }));

function fmtDate(s: string): string {
  // Accepts "2026-03-25" or "2026-03-25 12:00:00"
  const d = new Date(s);
  if (Number.isNaN(d.getTime())) return s;
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

// ---------- GOOGLE REVIEWS ----------
// Scraped from the live site at build time. See src/lib/google-reviews.ts.
const reviews = await fetchGoogleReviews();
// Duplicate the list so the vertical marquee loops seamlessly:
// keyframes animate from translateY(0) to translateY(-50%).
const reviewLoop = [...reviews, ...reviews];

// ---------- SERVICES ----------
const services = [
  {
    href: '/service-immobilier/syndic-de-copropriete-a-marseille/',
    icon: '/images/home/svc-syndic.svg',
    label: 'Syndic de copropriété à',
    city: 'Marseille',
  },
  {
    href: '/service-immobilier/gestion-locative/',
    icon: '/images/home/svc-gestion.svg',
    label: 'Gestion Locative à',
    city: 'Marseille',
  },
  {
    href: '/service-immobilier/vendre/',
    icon: '/images/home/svc-vendre.svg',
    label: 'Vendre',
    city: '',
  },
];

// Star icon as inline SVG path (re-used a few times)
const STAR_PATH =
  'M10 1l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9 4.7 17.1l1-5.8L1.5 7.2l5.9-.9z';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schemas={[buildWebSite()]}
  breadcrumb={false}
>
  {/* ============= HERO (full-bleed, outside boxed container) ============= */}
  <section class="hero">
    <video class="hero__video" autoplay muted loop playsinline preload="auto" poster="/images/home/hero-bg.jpg">
      <source src="https://pub-a37eed540afe4dc9b4479da74ba265e1.r2.dev/pujol-heor-bg.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>

    <div class="hero__inner">
      <h1>Nous croyons que l'immobilier<br />est fait de <b>belles expériences</b></h1>
    </div>

    <div class="hero-search">
      <div class="hero-search__tabs" id="heroTabs">
        <button class="hero-search__pill is-active" data-tab="estim" type="button">ESTIMATION EN LIGNE</button>
        <button class="hero-search__pill" data-tab="louer" type="button">VOIR LES BIENS À LOUER</button>
        <button class="hero-search__pill" data-tab="vendre" type="button">VOIR LES BIENS À VENDRE</button>
      </div>

        <div class="hero-search__bar" id="heroSearch">
          {/* ESTIMATION EN LIGNE */}
          <div class="hero-search__pane is-active" data-pane="estim">
            <div class="seg first">
              <span style="font-weight:700;font-size:13px;letter-spacing:.8px">VALEUR LOCATIVE</span>
              <svg width="12" height="8" viewBox="0 0 12 8"><path d="M1 1 L6 6 L11 1" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="round" /></svg>
            </div>
            <div class="input">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#666" stroke-width="1.6" /><path d="M16 16 L21 21" stroke="#666" stroke-width="1.6" stroke-linecap="round" /></svg>
              <span>Indiquez une adresse, un lieu, un métro...</span>
            </div>
            <a href="/services/estimation-prix-de-vente/" class="cta">ESTIMATION EN LIGNE</a>
          </div>

          {/* VOIR LES BIENS À LOUER */}
          <div class="hero-search__pane" data-pane="louer">
            <div class="seg first">
              <div class="lbl"><b>TYPE DE BIEN</b><span>Appartement, maison...</span></div>
              <svg width="12" height="8" viewBox="0 0 12 8"><path d="M1 1 L6 6 L11 1" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="round" /></svg>
            </div>
            <div class="seg">
              <div class="lbl"><b>BUDGET MAX</b><span>Loyer mensuel</span></div>
              <svg width="12" height="8" viewBox="0 0 12 8"><path d="M1 1 L6 6 L11 1" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="round" /></svg>
            </div>
            <div class="input">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#666" stroke-width="1.6" /><path d="M16 16 L21 21" stroke="#666" stroke-width="1.6" stroke-linecap="round" /></svg>
              <span>Indiquez une ville, un quartier...</span>
            </div>
            <a href="/annonces/locations/" class="cta">RECHERCHER</a>
          </div>

          {/* VOIR LES BIENS À VENDRE */}
          <div class="hero-search__pane" data-pane="vendre">
            <div class="seg first">
              <div class="lbl"><b>TYPE DE BIEN</b><span>Appartement, maison...</span></div>
              <svg width="12" height="8" viewBox="0 0 12 8"><path d="M1 1 L6 6 L11 1" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="round" /></svg>
            </div>
            <div class="seg">
              <div class="lbl"><b>BUDGET MAX</b><span>Prix d'achat</span></div>
              <svg width="12" height="8" viewBox="0 0 12 8"><path d="M1 1 L6 6 L11 1" stroke="#000" stroke-width="1.5" fill="none" stroke-linecap="round" /></svg>
            </div>
            <div class="input">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#666" stroke-width="1.6" /><path d="M16 16 L21 21" stroke="#666" stroke-width="1.6" stroke-linecap="round" /></svg>
              <span>Indiquez une ville, un quartier...</span>
            </div>
            <a href="/annonces/ventes/" class="cta">RECHERCHER</a>
          </div>
        </div>
      </div>
    </section>

    <script>
      (function () {
        const tabs = document.querySelectorAll('#heroTabs .hero-search__pill');
        const panes = document.querySelectorAll('#heroSearch .hero-search__pane');
        tabs.forEach((t) =>
          t.addEventListener('click', () => {
            tabs.forEach((x) => x.classList.remove('is-active'));
            t.classList.add('is-active');
            const which = (t as HTMLElement).dataset.tab;
            panes.forEach((p) =>
              p.classList.toggle('is-active', (p as HTMLElement).dataset.pane === which)
            );
          })
        );
      })();
    </script>

  <div class="home-page">

    {/* ============= SERVICES ============= */}
    <section class="services">
      <h2 class="ds-sec-title">Découvrir tous <b>nos services</b></h2>
      <div class="services__row">
        {services.map((s) => (
          <a class="svc-card" href={s.href}>
            <span class="ic"><img src={s.icon} alt="" /></span>
            <span class="lbl">
              {s.label}
              {s.city && <span class="city">{s.city}</span>}
            </span>
            <span class="arr">
              <svg width="22" height="14" viewBox="0 0 22 14" fill="none">
                <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    {/* ============= LISTINGS — two carousels (vente / location) ============= */}
    <section class="listings">
      <h2 class="ds-sec-title">Nos dernières <b>annonces</b></h2>

      <div class="listings__cols">
        {[
          { kind: 'vente', cards: venteCards, ctaHref: '/annonces/ventes/', ctaText: 'VOIR TOUTES NOS VENTES' },
          { kind: 'loc',   cards: locationCards, ctaHref: '/annonces/locations/', ctaText: 'VOIR TOUTES NOS LOCATIONS' },
        ].map((col) => (
          <div class={`listings__col listings__col--${col.kind}`} data-kind={col.kind}>
            <div class="listings__track">
              {col.cards.map((c) => (
                <a class={`listing-card ${c.isVente ? '' : 'listing-card--location'}`} href={c.href}>
                  <div class="photo" style={`background-image:url('${c.photo}')`}>
                    <span class={`badge ${c.isVente ? 'badge--vente' : ''}`}>{c.isVente ? 'VENTE' : 'LOCATION'}</span>
                  </div>
                  <div class="body">
                    <div class="title">{c.title}</div>
                    <div class="price">{c.price}</div>
                    {c.pills.length > 0 && (
                      <div class="meta">
                        {c.pills.map((p) => (
                          <span class="pill-tag">{p}</span>
                        ))}
                      </div>
                    )}
                    {(c.quartier || c.cpVille) && (
                      <div class="loc">
                        {c.quartier && <span class="a">{c.quartier}</span>}
                        {c.cpVille && <span>{c.cpVille}</span>}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>
            <div class="listings__arrows">
              <button type="button" class="arrow-btn" data-listings-prev aria-label="Annonces précédentes">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 6 L9 12 L15 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg>
              </button>
              <button type="button" class="arrow-btn" data-listings-next aria-label="Annonces suivantes">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 6 L15 12 L9 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg>
              </button>
            </div>
            <a class={`btn-pill-cta btn-pill-cta--${col.kind}`} href={col.ctaHref}>{col.ctaText}</a>
          </div>
        ))}
      </div>
    </section>

    <script>
      (function () {
        document.querySelectorAll<HTMLElement>('.listings__col').forEach((col) => {
          const track = col.querySelector<HTMLElement>('.listings__track');
          const prev = col.querySelector<HTMLButtonElement>('[data-listings-prev]');
          const next = col.querySelector<HTMLButtonElement>('[data-listings-next]');
          if (!track || !prev || !next) return;

          const cardsPerPage = 2;

          function step(): number {
            const card = track!.querySelector<HTMLElement>('.listing-card');
            if (!card) return 0;
            const styles = getComputedStyle(track!);
            const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
            return (card.offsetWidth + gap) * cardsPerPage;
          }

          prev.addEventListener('click', () => track!.scrollBy({ left: -step(), behavior: 'smooth' }));
          next.addEventListener('click', () => track!.scrollBy({ left:  step(), behavior: 'smooth' }));
        });
      })();
    </script>

    {/* ============= EXPERTS — horizontal-scroll carousel ============= */}
    <section class="experts">
      <div class="experts__head">
        <h2>Nos <b>Experts</b></h2>
        <div class="experts__arrows">
          <button class="arrow-btn" id="expertPrev" type="button" aria-label="Précédent"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 6 L9 12 L15 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg></button>
          <button class="arrow-btn" id="expertNext" type="button" aria-label="Suivant"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 6 L15 12 L9 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg></button>
        </div>
      </div>
      <div class="experts__row" id="expertsRow">
        {experts.map((e) => (
          <a class="expert" href={e.href}>
            <div class="ph"><img src={e.photo} alt={`${e.first} ${e.last}`.trim()} /></div>
            <div class="name">
              {e.first && <>{e.first} </>}<b>{e.last}</b>
            </div>
            <div class="role">{e.role}</div>
          </a>
        ))}
      </div>
    </section>

    <script>
      (function () {
        const row = document.getElementById('expertsRow');
        const prev = document.getElementById('expertPrev');
        const next = document.getElementById('expertNext');
        if (!row || !prev || !next) return;
        const step = () => {
          const card = row.querySelector<HTMLElement>('.expert');
          if (!card) return 0;
          const styles = getComputedStyle(row);
          const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
          // Scroll one expert at a time.
          return card.offsetWidth + gap;
        };
        prev.addEventListener('click', () => row.scrollBy({ left: -step(), behavior: 'smooth' }));
        next.addEventListener('click', () => row.scrollBy({ left:  step(), behavior: 'smooth' }));
      })();
    </script>

    {/* ============= ABOUT ============= */}
    <section class="about">
      <div class="left">
        <h2>Nous sommes une<br />entreprise indépendante<br /><b>Crée en 2002</b></h2>
        <p>Nous avons fait le choix de la qualité et du service pour nos clients et nos collaborateurs à qui nous donnons un confort de travail et des outils efficaces.</p>
        <p>Nous avons construit au fil des années une agence immobilière qui a développé des solutions innovantes, pour prendre soin de ses clients, les sécuriser dans leurs choix et leurs projets.</p>
      </div>
      <div class="right">
        <img class="photo" src="/images/home/about-building.png" alt="" />
      </div>
    </section>

    {/* ============= STATS + TESTIMONIALS ============= */}
    <section class="about-stats">
      <div class="testi-stage">
        <div class="testi-viewport" id="testiViewport">
          <div class="testi-col" id="testiCol">
            {reviewLoop.map((r) => (
              <div class="testi">
                <div class="stars">
                  {Array.from({ length: r.rating }).map(() => (
                    <svg viewBox="0 0 20 20" fill="currentColor"><path d={STAR_PATH} /></svg>
                  ))}
                </div>
                <p>{r.text}</p>
                <h4>{r.author}</h4>
                <img class="g" src="/images/home/google-g.png" alt="" />
              </div>
            ))}
          </div>
        </div>
        <div class="testi-arrows">
          <button class="arrow-btn" id="testiPrev" type="button" aria-label="Avis précédent">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 15 L12 9 L18 15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg>
          </button>
          <button class="arrow-btn" id="testiNext" type="button" aria-label="Avis suivant">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9 L12 15 L18 9" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg>
          </button>
        </div>
      </div>

      <div>
        <div class="stat-num">4.7<span class="small">/5</span></div>
        <div class="stat-stars">
          {[1, 2, 3, 4, 5].map(() => (
            <svg viewBox="0 0 20 20" fill="currentColor"><path d={STAR_PATH} /></svg>
          ))}
        </div>
        <div class="stat-reviews"><img src="/images/home/google-g.png" alt="" /> 2008 reviews</div>
        <h3 class="stat-title">Plus de 2000<br /><b>Clients satisfaits</b></h3>
        <p class="stat-sub">La satisfaction de nos clients est notre plus belle réussite. Merci pour votre confiance et vos avis qui nous motivent chaque jour.</p>
      </div>
    </section>

    <script>
      (function () {
        const col = document.getElementById('testiCol');
        const prev = document.getElementById('testiPrev');
        const next = document.getElementById('testiNext');
        if (!col || !prev || !next) return;

        // Reviews are duplicated in the DOM so wrap-around feels seamless
        // when the user steps past the halfway mark (== one full set).
        let offset = 0;

        function step(): number {
          const card = col!.querySelector<HTMLElement>('.testi');
          if (!card) return 0;
          const styles = getComputedStyle(col!);
          const gap = parseFloat(styles.rowGap || styles.gap || '0') || 0;
          return card.offsetHeight + gap;
        }

        function loopMax(): number {
          return col!.scrollHeight / 2;
        }

        function nudge(direction: 1 | -1) {
          const s = step();
          const max = loopMax();
          if (s <= 0 || max <= 0) return;
          offset = ((offset + s * direction) % max + max) % max;
          col!.style.transition = 'transform 0.45s cubic-bezier(.19,.68,.27,1)';
          col!.style.transform = `translateY(${-offset}px)`;
          setTimeout(() => { col!.style.transition = ''; }, 500);
        }

        prev.addEventListener('click', () => nudge(-1));
        next.addEventListener('click', () => nudge(1));
      })();
    </script>

    {/* ============= BLOG ============= */}
    <section class="blog">
      <div class="blog__head">
        <div>
          <div class="blog__script">Notre blog</div>
          <h2><b>En direct</b></h2>
        </div>
        <div class="experts__arrows">
          <button class="arrow-btn" id="blogPrev" type="button" aria-label="Précédent"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 6 L9 12 L15 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg></button>
          <button class="arrow-btn" id="blogNext" type="button" aria-label="Suivant"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 6 L15 12 L9 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" /></svg></button>
        </div>
      </div>
      <div class="blog__grid" id="blogGrid">
        {articles.map((a) => (
          <a class="post" href={a.href}>
            <div class="img" style={`background-image:url('${a.img}')`}></div>
            <div class="meta"><span>{fmtDate(a.date)}</span></div>
            <h3>{a.title}</h3>
            <p>{a.excerpt}</p>
          </a>
        ))}
      </div>
    </section>

    <script>
      (function () {
        const grid = document.getElementById('blogGrid');
        const prev = document.getElementById('blogPrev');
        const next = document.getElementById('blogNext');
        if (!grid || !prev || !next) return;
        const step = () => {
          const card = grid.querySelector('.post') as HTMLElement | null;
          if (!card) return 0;
          const styles = getComputedStyle(grid);
          const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
          // Scroll one "page" of 4 cards at a time.
          return (card.offsetWidth + gap) * 4;
        };
        prev.addEventListener('click', () => grid.scrollBy({ left: -step(), behavior: 'smooth' }));
        next.addEventListener('click', () => grid.scrollBy({ left:  step(), behavior: 'smooth' }));
      })();
    </script>

    {/* ============= NEWSLETTER ============= */}
    <section class="news-wrap">
      <form class="news" method="post" action="/api/newsletter/">
        <h2>Inscrivez-vous à la<br /><b>Newsletter</b></h2>
        <div class="form">
          <input name="email" type="email" placeholder="Email" required />
          <button class="submit" type="submit" aria-label="S'inscrire">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 12 H19 M13 6 L19 12 L13 18" stroke="#fff" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
        </div>
        <label class="agree">
          <input type="checkbox" name="agree" class="check" required />
