---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { buildWebSite } from '../lib/schemas';

// Home content was scraped from live into src/content/pages/home.md.
// We render its body directly (HTML), same pattern as other pages.
const entry = await getEntry('pages', 'home');
const rawBody = entry ? (entry as any).body ?? '' : '';
const seoTitle = entry?.data.seoTitle || "Immobilière Pujol – L'agence immobilière la plus recommandée par ses clients";
const seoDescription = entry?.data.seoDescription || '';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schemas={[buildWebSite()]}
  breadcrumb={false}
>
  <div class="home-content" set:html={rawBody}></div>
</BaseLayout>
