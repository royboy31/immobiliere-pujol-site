---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchActiveListings } from '../../lib/r2-annonces';
import { buildArrondissements, buildKindOptions } from '../../lib/annonces-filter';
import AnnonceCard from '../../components/annonces/AnnonceCard.astro';
import FilterBar from '../../components/annonces/FilterBar.astro';

const allAnnonces = await fetchActiveListings();
const annonces = allAnnonces.filter(a => a.type === 'L');
const ventes = allAnnonces.filter(a => a.type === 'V');

const kinds = buildKindOptions(annonces);
const arrondissements = buildArrondissements(annonces);
---

<BaseLayout
  title="Location appartement Marseille – Immobilière Pujol"
  description="Découvrez toutes nos annonces de location d'appartements et maisons à Marseille."
>
  <div class="annonces-page">
    <section class="annonces-hero">
      <h1>Nos <b>locations</b> à Marseille</h1>
      <p class="annonces-hero__sub">
        {annonces.length} biens à louer sélectionnés par notre équipe — appartements, maisons, parkings et plus encore.
      </p>
      <nav class="annonces-pills">
        <a href="/annonces/">Toutes <span class="count">({allAnnonces.length})</span></a>
        <a href="/annonces/locations/" class="is-active" data-kind="loc">Locations <span class="count">({annonces.length})</span></a>
        <a href="/annonces/ventes/" data-kind="vente">Ventes <span class="count">({ventes.length})</span></a>
      </nav>
    </section>

    <section class="annonces-filter-section">
      <FilterBar kinds={kinds} arrondissements={arrondissements} scope="L" />
    </section>

    <section class="annonces-grid-section">
      {annonces.length > 0 ? (
        <>
          <div class="annonces-grid">
            {annonces.map((a) => <AnnonceCard annonce={a} />)}
          </div>
          <div class="annonces-empty annonces-empty--filter" hidden>
            <h2>Aucun bien <b>ne correspond</b></h2>
            <p>Essayez d'élargir vos critères ou contactez notre équipe pour un projet sur mesure.</p>
            <a href="/contact-immobiliere-pujol/" class="btn-pill btn-pill--olive">NOUS CONTACTER</a>
          </div>
        </>
      ) : (
        <div class="annonces-empty">
          <h2>Aucune <b>location</b> pour le moment</h2>
          <p>Faites-nous part de votre projet et nous vous proposerons des biens dès qu'ils seront disponibles.</p>
          <a href="/contact-immobiliere-pujol/" class="btn-pill btn-pill--olive">NOUS CONTACTER</a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
