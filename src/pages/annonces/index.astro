---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getActiveAnnonces, formatDbPrice } from '../../lib/db-annonces';

const { env } = await import('cloudflare:workers');
const allAnnonces = await getActiveAnnonces((env as any).DB);
const annonces = allAnnonces;
const ventes = annonces.filter(a => a.type_annonce === 'V');
const locations = annonces.filter(a => a.type_annonce === 'L');
---

<BaseLayout
  title="Annonces immobilières à Marseille – Immobilière Pujol"
  description="Découvrez toutes nos annonces immobilières de location et de vente à Marseille."
>
  <section class="annonces-listing">
    <header class="annonces-listing__header">
      <h1>Nos annonces immobilières</h1>
      <p>{allAnnonces.length} annonces disponibles ({ventes.length} ventes, {locations.length} locations)</p>
      <nav class="annonces-listing__filters">
        <a href="/annonces/" class="active">Toutes ({allAnnonces.length})</a>
        <a href="/annonces/locations/">Locations ({locations.length})</a>
        <a href="/annonces/ventes/">Ventes ({ventes.length})</a>
      </nav>
    </header>

    <div class="annonces-listing__grid">
      {annonces.map((annonce) => (
        <a href={`/annonces/${annonce.slug}/`} class="annonce-card">
          <div class="annonce-card__image">
            {annonce.photos[0] ? (
              <img src={annonce.photos[0]} alt={annonce.titre} loading="lazy" width="400" height="267" />
            ) : (
              <div class="annonce-card__placeholder">Pas de photo</div>
            )}
            <span class:list={['annonce-card__badge', annonce.type_annonce === 'V' ? 'badge--vente' : 'badge--location']}>
              {annonce.type_annonce === 'V' ? 'Vente' : 'Location'}
            </span>
          </div>
          <div class="annonce-card__content">
            <h2 class="annonce-card__title">{annonce.titre}</h2>
            <p class="annonce-card__price">{formatDbPrice(annonce)}</p>
            <div class="annonce-card__details">
              {annonce.type_bien && <span>{annonce.type_bien}</span>}
              {annonce.surface && <span>{annonce.surface} m²</span>}
              {annonce.nb_pieces && <span>{annonce.nb_pieces} pièce{annonce.nb_pieces > 1 ? 's' : ''}</span>}
              {annonce.quartier && <span>{annonce.quartier}</span>}
              <span>{annonce.code_postal} {annonce.ville}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

