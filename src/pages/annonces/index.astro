---
import BaseLayout from '../../layouts/BaseLayout.astro';
// All listings page with filter system
---

<BaseLayout
  title="Annonces immobilières à Marseille – Immobilière Pujol"
  description="Découvrez toutes nos annonces immobilières de location et de vente à Marseille."
>
  <section class="ads-archive">
    <div class="ads-archive__search">
      <!-- Filter bar: type, rooms, price range, arrondissement -->
    </div>
    <div class="ads-archive__results">
      <div class="ads-archive__list">
        <!-- Property cards -->
      </div>
      <div class="ads-archive__map">
        <!-- Leaflet map -->
      </div>
    </div>
  </section>
</BaseLayout>
