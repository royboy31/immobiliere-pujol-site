---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchUbiflowAnnonces } from '../../lib/ubiflow';
import { buildArrondissements, buildKindOptions } from '../../lib/annonces-filter';
import AnnonceCard from '../../components/annonces/AnnonceCard.astro';
import FilterBar from '../../components/annonces/FilterBar.astro';

const allAnnonces = await fetchUbiflowAnnonces();
const annonces = allAnnonces.filter(a => a.type === 'V');
const locations = allAnnonces.filter(a => a.type === 'L');

const kinds = buildKindOptions(annonces);
const arrondissements = buildArrondissements(annonces);
---

<BaseLayout
  title="Vente appartement Marseille – Immobilière Pujol"
  description="Découvrez toutes nos annonces de vente d'appartements et maisons à Marseille."
>
  <div class="annonces-page">
    <section class="annonces-hero">
      <h1>Nos <b>ventes</b> à Marseille</h1>
      <p class="annonces-hero__sub">
        {annonces.length} biens à vendre — appartements, maisons et programmes neufs sélectionnés par notre équipe.
      </p>
      <nav class="annonces-pills">
        <a href="/annonces/">Toutes <span class="count">({allAnnonces.length})</span></a>
        <a href="/annonces/locations/" data-kind="loc">Locations <span class="count">({locations.length})</span></a>
        <a href="/annonces/ventes/" class="is-active" data-kind="vente">Ventes <span class="count">({annonces.length})</span></a>
      </nav>
    </section>

    <section class="annonces-filter-section">
      <FilterBar kinds={kinds} arrondissements={arrondissements} scope="V" />
    </section>

    <section class="annonces-grid-section">
      {annonces.length > 0 ? (
        <>
          <div class="annonces-grid">
            {annonces.map((a) => <AnnonceCard annonce={a} />)}
          </div>
          <div class="annonces-empty annonces-empty--filter" hidden>
            <h2>Aucun bien <b>ne correspond</b></h2>
            <p>Essayez d'élargir vos critères ou contactez notre équipe pour un projet sur mesure.</p>
            <a href="/contact-immobiliere-pujol/" class="btn-pill btn-pill--olive">NOUS CONTACTER</a>
          </div>
        </>
      ) : (
        <div class="annonces-empty">
          <h2>Aucune <b>vente</b> pour le moment</h2>
          <p>Vous cherchez un bien à acheter ? Faites-nous part de votre projet et nous vous tiendrons informé.</p>
          <a href="/contact-immobiliere-pujol/" class="btn-pill btn-pill--olive">NOUS CONTACTER</a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
