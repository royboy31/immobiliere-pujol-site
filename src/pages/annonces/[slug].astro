---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAnnonceBySlug, getSimilarPool, getRelatedAnnonces, formatDbPrice, extractTourUrl } from '../../lib/db-annonces';
import { findExpertByEmail } from '../../lib/experts';
import { getClosedAnnonce, formatClosedPrice, type ClosedAnnonce } from '../../lib/closed-annonces';
import { buildRealEstateListing } from '../../lib/schemas';
import AnnonceLive from '../../components/annonces/AnnonceLive.astro';
import AnnonceClosed from '../../components/annonces/AnnonceClosed.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/annonces/');

const { env } = await import('cloudflare:workers');
const db = (env as any).DB as D1Database;

// Single D1 lookup — handles both active and closed annonces
const annonce = await getAnnonceBySlug(db, slug);

if (!annonce) {
  // Fallback: try loading from static assets (for annonces not yet seeded to D1)
  const { getClosedAnnonce } = await import('../../lib/closed-annonces');
  const assets = (env as any)?.ASSETS;
  const closed = await getClosedAnnonce(slug, assets, new URL(Astro.url.origin));
  if (!closed) return Astro.redirect('/annonces/');

  // Redirect will be removed once all annonces are seeded to D1
  // For now, render closed annonce from static assets with same template
}

const isClosed = annonce ? annonce.status === 'closed' : true;

// Build view model from D1 data
const expert = annonce ? findExpertByEmail(annonce.email_a_afficher) : null;

type View = {
  titre: string;
  description: string;
  type: string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  adresse?: string | null;
  codePostal?: string | null;
  ville?: string | null;
  quartier?: string | null;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | null;
  nbEtages?: string | null;
  meuble?: number | null;
  typeChauffage?: string | null;
  dpeEtiquetteConso?: string | null;
  dpeEtiquetteGes?: string | null;
  dpeValeurConso?: string | null;
  dpeValeurGes?: string | null;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honoraires?: string | null;
  honorairesEtatDesLieux?: number | null;
  honorairesChargeAcquereur?: boolean;
  visiteVirtuelle?: string;
  tourEmbedAllowed?: boolean;
  isClosed: boolean;
  latitude?: number | null;
  longitude?: number | null;
  related: { slug: string; title: string; prix: number | null; type: string; cp: string }[];
  contactAAfficher?: string | null;
  telephoneAAfficher?: string | null;
  emailAAfficher?: string | null;
};

let view: View;

if (annonce) {
  const related = isClosed && annonce.code_postal
    ? await getRelatedAnnonces(db, annonce.code_postal, slug)
    : [];

  // Some legacy fields arrive triple-duplicated, separated by "|" — keep just the first.
  const dedupePipes = (s: string | null | undefined): string =>
    s ? s.split('|')[0].trim() : '';

  // Strip the trailing "CP, ville, [country]" from the adresse so it doesn't repeat
  // the CP/ville we render on the next line.
  const streetOnly = (adresse: string | null | undefined): string => {
    if (!adresse) return '';
    const parts = adresse.split(',').map(p => p.trim()).filter(Boolean);
    const cpIdx = parts.findIndex(p => /^\d{5}$/.test(p));
    return (cpIdx >= 0 ? parts.slice(0, cpIdx) : parts).join(', ');
  };

  // Strip trailing ", France" / ", FR" that some legacy values carry inside fields.
  const stripCountry = (s: string): string =>
    s.replace(/\s*,\s*(France|FR|France\.?)\s*$/i, '').trim();

  const cleanAdresse = stripCountry(streetOnly(dedupePipes(annonce.adresse)));
  const cleanVille = stripCountry(dedupePipes(annonce.ville));
  const cleanQuartier = dedupePipes(annonce.quartier);
  // Hide quartier when it's already implied by the street (e.g. street "…, Cabot" + quartier "Cabot").
  const quartierForDisplay =
    cleanQuartier && !cleanAdresse.toLowerCase().includes(cleanQuartier.toLowerCase())
      ? cleanQuartier
      : null;

  // Use stored titre only when it's human-readable — many legacy rows store a SKU
  // like "LO33790006_307F". A space is the cheapest "looks like a sentence" check.
  const storedTitre = dedupePipes(annonce.titre);
  const titreLooksHuman = storedTitre.includes(' ');
  let titre = titreLooksHuman ? storedTitre : '';
  if (!titre) {
    const baseType = dedupePipes(annonce.libelle) || 'Bien';
    const action = annonce.type_annonce === 'V' ? 'à vendre' : 'à louer';
    const cityHint = cleanVille ? ` à ${cleanVille}` : annonce.code_postal ? ` (${annonce.code_postal})` : '';
    titre = `${baseType} ${action}${cityHint}`.trim();
  }

  view = {
    titre,
    description: annonce.descriptif || '',
    type: annonce.type_annonce || 'V',
    reference: annonce.ubiflow_reference || annonce.reference_agence || annonce.slug,
    priceDisplay: formatDbPrice(annonce),
    photos: annonce.photos,
    adresse: cleanAdresse,
    codePostal: annonce.code_postal,
    ville: cleanVille,
    quartier: quartierForDisplay,
    surface: annonce.surface,
    nbPieces: annonce.nb_pieces,
    nbChambres: annonce.nb_chambres,
    nbSallesDeBain: annonce.nb_salles_bain,
    nbWC: annonce.nb_wc,
    etage: annonce.etage,
    nbEtages: annonce.nb_etages,
    meuble: annonce.meuble,
    typeChauffage: annonce.type_chauffage,
    dpeEtiquetteConso: annonce.dpe_note,
    dpeEtiquetteGes: annonce.ges_note,
    dpeValeurConso: annonce.dpe_valeur,
    dpeValeurGes: annonce.ges_valeur,
    loyer: annonce.loyer_ht,
    loyerCC: annonce.loyer_cc,
    charges: annonce.charges,
    depotGarantie: annonce.depot_garantie,
    prix: annonce.prix,
    honoraires: annonce.honoraires,
    honorairesEtatDesLieux: annonce.honoraires_etat_des_lieux,
    honorairesChargeAcquereur: false,
    visiteVirtuelle:
      dedupePipes(annonce.url_visite_virtuelle) ||
      extractTourUrl(annonce.descriptif),
    tourEmbedAllowed: !!dedupePipes(annonce.url_visite_virtuelle),
    isClosed,
    latitude: annonce.latitude,
    longitude: annonce.longitude,
    related: related.map(r => ({
      slug: r.slug,
      title: r.titre,
      prix: r.prix,
      type: r.type_annonce,
      cp: r.code_postal,
    })),
    contactAAfficher: annonce.contact_a_afficher,
    telephoneAAfficher: annonce.telephone_a_afficher,
    emailAAfficher: annonce.email_a_afficher,
  };
} else {
  return Astro.redirect('/annonces/');
}

// Load a small set of similar annonces for "Biens similaires"
const similarAnnonces = await getSimilarPool(db, slug, view.type, view.codePostal ?? null);
const pool = similarAnnonces.map(a => ({
  id: String(a.id),
  reference: a.ubiflow_reference || a.reference_agence || '',
  titre: a.titre || '',
  description: a.descriptif || '',
  dateSaisie: '',
  contactAAfficher: a.contact_a_afficher || '',
  emailAAfficher: a.email_a_afficher || '',
  telephoneAAfficher: a.telephone_a_afficher || '',
  type: (a.type_annonce || 'V') as 'V' | 'L',
  prix: a.prix,
  prixHorsHonoraires: null,
  loyer: a.loyer_ht,
  loyerCC: a.loyer_cc,
  charges: a.charges,
  depotGarantie: a.depot_garantie,
  honorairesChargeAcquereur: false,
  devise: 'EUR',
  libelleType: a.type_bien || '',
  codePostal: a.code_postal || '',
  adresse: a.adresse || '',
  ville: a.ville || '',
  quartier: a.quartier || '',
  latitude: a.latitude,
  longitude: a.longitude,
  surface: a.surface,
  surfaceHabitable: null,
  surfaceTerrain: a.surface_terrain,
  surfaceTerrasse: null,
  nbPieces: a.nb_pieces,
  nbChambres: a.nb_chambres,
  nbSallesDeBain: a.nb_salles_bain,
  nbWC: a.nb_wc,
  etage: a.etage || '',
  nbEtages: a.nb_etages || '',
  exposition: '',
  cuisine: '',
  typeChauffage: a.type_chauffage || '',
  chauffageEnergie: '',
  meuble: !!a.meuble,
  ascenseur: !!a.ascenseur,
  terrasse: !!a.terrasse,
  balcon: false,
  garage: !!a.garage,
  parking: !!a.parking,
  cave: !!a.cave,
  interphone: !!a.interphone,
  copropriete: false,
  chargesCopropriete: null,
  alurNbLots: null,
  anneeConstruction: '',
  vueSurMer: false,
  dpeValeurConso: a.dpe_valeur || '',
  dpeEtiquetteConso: a.dpe_note || '',
  dpeEtiquetteGes: a.ges_note || '',
  dpeEstimationMin: '',
  dpeEstimationMax: '',
  dpeValeurGes: '',
  photos: a.photos,
  visiteVirtuelle: '',
  mandatNumero: a.mandat_numero || '',
  mandatType: a.mandat_type || '',
  slug: a.slug,
}));

const pageTitle = `${view.titre} – Immobilière Pujol`;
const pageDescription = view.description ? view.description.substring(0, 160) : pageTitle;

const annonceUrl = new URL(`/annonces/${slug}/`, Astro.site).toString();
const listingSchema = buildRealEstateListing({
  titre: view.titre,
  description: view.description,
  slug: slug,
  type: view.type,
  prix: view.prix ?? null,
  loyerCC: view.loyerCC ?? null,
  surface: view.surface ?? null,
  nbPieces: view.nbPieces ?? null,
  adresse: view.adresse,
  codePostal: view.codePostal,
  ville: view.ville,
  photos: view.photos,
}, annonceUrl);
---

<BaseLayout title={pageTitle} description={pageDescription} schemas={[listingSchema]}>
  {!view.isClosed ? (
    <AnnonceLive
      view={view}
      contactName={view.contactAAfficher}
      contactEmail={view.emailAAfficher}
      expert={expert}
      pool={pool}
      currentSlug={slug ?? ''}
    />
  ) : (
    <AnnonceClosed
      view={view}
      expert={expert}
      related={view.related}
      pool={pool}
      currentSlug={slug ?? ''}
    />
  )}
</BaseLayout>
