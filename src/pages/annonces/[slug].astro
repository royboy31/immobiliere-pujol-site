---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAnnonceBySlug, getRelatedAnnonces, formatDbPrice } from '../../lib/db-annonces';
import { findExpertByEmail } from '../../lib/experts';
import ExpertCard from '../../components/experts/ExpertCard.astro';
import { buildRealEstateListing } from '../../lib/schemas';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/annonces/');

const { env } = await import('cloudflare:workers');
const db = (env as any).DB as D1Database;

// Single D1 lookup — handles both active and closed annonces
const annonce = await getAnnonceBySlug(db, slug);

if (!annonce) {
  // Fallback: try loading from static assets (for annonces not yet seeded to D1)
  const { getClosedAnnonce } = await import('../../lib/closed-annonces');
  const assets = (env as any)?.ASSETS;
  const closed = await getClosedAnnonce(slug, assets, new URL(Astro.url.origin));
  if (!closed) return Astro.redirect('/annonces/');

  // Redirect will be removed once all annonces are seeded to D1
  // For now, render closed annonce from static assets with same template
}

const isClosed = annonce ? annonce.status === 'closed' : true;

// Build view model from D1 data
const expert = annonce ? findExpertByEmail(annonce.email_a_afficher) : null;

type View = {
  titre: string;
  description: string;
  type: string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  adresse?: string | null;
  codePostal?: string | null;
  ville?: string | null;
  quartier?: string | null;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | null;
  nbEtages?: string | null;
  typeChauffage?: string | null;
  dpeEtiquetteConso?: string | null;
  dpeEtiquetteGes?: string | null;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honoraires?: string | null;
  isClosed: boolean;
  related: { slug: string; titre: string; prix: number | null; type_annonce: string; code_postal: string }[];
  contactAAfficher?: string | null;
  telephoneAAfficher?: string | null;
  emailAAfficher?: string | null;
};

let view: View;

if (annonce) {
  const related = isClosed && annonce.code_postal
    ? await getRelatedAnnonces(db, annonce.code_postal, slug)
    : [];

  let titre = annonce.titre;
  if (isClosed && !titre) {
    const pieces = annonce.nb_pieces ? ` ${annonce.nb_pieces} pièce${annonce.nb_pieces > 1 ? 's' : ''}` : '';
    const surface = annonce.surface ? ` de ${annonce.surface} m²` : '';
    const where = [annonce.ville, annonce.code_postal ? `(${annonce.code_postal})` : ''].filter(Boolean).join(' ');
    const action = annonce.type_annonce === 'V' ? 'à vendre' : 'à louer';
    titre = `Appartement${pieces}${surface} ${action}${where ? ' à ' + where : ''}`.trim();
  }

  view = {
    titre,
    description: annonce.descriptif || '',
    type: annonce.type_annonce || 'V',
    reference: annonce.ubiflow_reference || annonce.reference_agence || annonce.slug,
    priceDisplay: formatDbPrice(annonce),
    photos: annonce.photos,
    adresse: annonce.adresse,
    codePostal: annonce.code_postal,
    ville: annonce.ville,
    quartier: annonce.quartier,
    surface: annonce.surface,
    nbPieces: annonce.nb_pieces,
    nbChambres: annonce.nb_chambres,
    nbSallesDeBain: annonce.nb_salles_bain,
    nbWC: annonce.nb_wc,
    etage: annonce.etage,
    nbEtages: annonce.nb_etages,
    typeChauffage: annonce.type_chauffage,
    dpeEtiquetteConso: annonce.dpe_note,
    dpeEtiquetteGes: annonce.ges_note,
    loyer: annonce.loyer_ht,
    loyerCC: annonce.loyer_cc,
    charges: annonce.charges,
    depotGarantie: annonce.depot_garantie,
    prix: annonce.prix,
    honoraires: annonce.honoraires,
    isClosed,
    related,
    contactAAfficher: annonce.contact_a_afficher,
    telephoneAAfficher: annonce.telephone_a_afficher,
    emailAAfficher: annonce.email_a_afficher,
  };
} else {
  return Astro.redirect('/annonces/');
}

const pageTitle = `${view.titre} – Immobilière Pujol`;
const pageDescription = view.description ? view.description.substring(0, 160) : pageTitle;

const annonceUrl = new URL(`/annonces/${slug}/`, Astro.site).toString();
const listingSchema = buildRealEstateListing({
  titre: view.titre,
  description: view.description,
  slug: slug,
  type: view.type,
  prix: view.prix ?? null,
  loyerCC: view.loyerCC ?? null,
  surface: view.surface ?? null,
  nbPieces: view.nbPieces ?? null,
  adresse: view.adresse,
  codePostal: view.codePostal,
  ville: view.ville,
  photos: view.photos,
}, annonceUrl);
---

<BaseLayout title={pageTitle} description={pageDescription} schemas={[listingSchema]}>
  <article class="annonce-single">
    {view.isClosed && (
      <div class="annonce-single__closed-banner">
        <p>
          <strong>{view.type === 'V' ? 'Vente' : 'Location'} clôturée</strong> — cette annonce n'est plus disponible.
          <a href="/annonces/">Voir nos annonces actuelles</a>.
        </p>
      </div>
    )}

    <!-- Photo gallery -->
    <section class="annonce-single__gallery">
      {view.photos.length > 0 ? (
        <div class="gallery">
          <div class="gallery__main">
            <img src={view.photos[0]} alt={view.titre} id="main-photo" loading="eager" />
          </div>
          {view.photos.length > 1 && (
            <div class="gallery__thumbs">
              {view.photos.map((photo, i) => (
                <button class="gallery__thumb" data-index={i} data-src={photo}>
                  <img src={photo} alt={`Photo ${i + 1}`} loading="lazy" width="120" height="80" />
                </button>
              ))}
            </div>
          )}
          <p class="gallery__count">{view.photos.length} photo{view.photos.length > 1 ? 's' : ''}</p>
        </div>
      ) : (
        <div class="gallery__empty">Pas de photos disponibles</div>
      )}
    </section>

    <!-- Main info -->
    <section class="annonce-single__info">
      <div class="annonce-single__header">
        <h1>{view.titre}</h1>
        <div class="annonce-single__price-block">
          {view.priceDisplay && <span class="annonce-single__price">{view.priceDisplay}</span>}
          <span class:list={['annonce-single__badge', view.type === 'V' ? 'badge--vente' : 'badge--location']}>
            {view.type === 'V' ? 'Vente' : 'Location'}
          </span>
        </div>
      </div>

      <div class="annonce-single__location">
        <p>{view.adresse && `${view.adresse}, `}{view.codePostal} {view.ville}</p>
        {view.quartier && <p>Quartier : {view.quartier}</p>}
      </div>

      <!-- Key figures -->
      <div class="annonce-single__key-figures">
        {view.surface && (
          <div class="key-figure">
            <span class="key-figure__value">{view.surface} m²</span>
            <span class="key-figure__label">Surface</span>
          </div>
        )}
        {view.nbPieces && (
          <div class="key-figure">
            <span class="key-figure__value">{view.nbPieces}</span>
            <span class="key-figure__label">Pièce{view.nbPieces > 1 ? 's' : ''}</span>
          </div>
        )}
        {view.nbChambres && (
          <div class="key-figure">
            <span class="key-figure__value">{view.nbChambres}</span>
            <span class="key-figure__label">Chambre{view.nbChambres > 1 ? 's' : ''}</span>
          </div>
        )}
        {view.etage && (
          <div class="key-figure">
            <span class="key-figure__value">{view.etage}{view.nbEtages ? `/${view.nbEtages}` : ''}</span>
            <span class="key-figure__label">Étage</span>
          </div>
        )}
      </div>
    </section>

    <!-- Description -->
    {view.description && (
      <section class="annonce-single__description">
        <h2>Description</h2>
        <div class="description-text" set:html={view.description.replace(/\n/g, '<br/>')}></div>
      </section>
    )}

    <!-- Property details -->
    <section class="annonce-single__details">
      <h2>Caractéristiques</h2>
      <div class="details-grid">
        <div class="details-group">
          <h3>Général</h3>
          <dl>
            {view.surface && <><dt>Surface</dt><dd>{view.surface} m²</dd></>}
            {view.nbPieces && <><dt>Pièces</dt><dd>{view.nbPieces}</dd></>}
            {view.nbChambres && <><dt>Chambres</dt><dd>{view.nbChambres}</dd></>}
            {view.nbSallesDeBain && <><dt>Salles de bain</dt><dd>{view.nbSallesDeBain}</dd></>}
            {view.nbWC && <><dt>WC</dt><dd>{view.nbWC}</dd></>}
          </dl>
        </div>

        {view.typeChauffage && (
          <div class="details-group">
            <h3>Chauffage</h3>
            <dl>
              <dt>Type</dt><dd>{view.typeChauffage}</dd>
            </dl>
          </div>
        )}

        {view.type === 'L' && (
          <div class="details-group">
            <h3>Location</h3>
            <dl>
              {view.loyer && <><dt>Loyer HC</dt><dd>{view.loyer} €</dd></>}
              {view.loyerCC && <><dt>Loyer CC</dt><dd>{view.loyerCC} €/mois</dd></>}
              {view.charges && <><dt>Charges</dt><dd>{view.charges} €/mois</dd></>}
              {view.depotGarantie && <><dt>Dépôt de garantie</dt><dd>{view.depotGarantie} €</dd></>}
            </dl>
          </div>
        )}

        {view.type === 'V' && view.prix && (
          <div class="details-group">
            <h3>Vente</h3>
            <dl>
              <dt>Prix</dt><dd>{new Intl.NumberFormat('fr-FR').format(view.prix)} €</dd>
              {view.honoraires && <><dt>Honoraires</dt><dd>{view.honoraires}</dd></>}
            </dl>
          </div>
        )}
      </div>
    </section>

    <!-- DPE -->
    {(view.dpeEtiquetteConso || view.dpeEtiquetteGes) && (
      <section class="annonce-single__dpe">
        <h2>Diagnostics de performance</h2>
        <div class="dpe-badges">
          {view.dpeEtiquetteConso && (
            <div class="dpe-badge">
              <span class="dpe-badge__label">DPE</span>
              <span class:list={['dpe-badge__value', `dpe-${view.dpeEtiquetteConso.toLowerCase()}`]}>
                {view.dpeEtiquetteConso}
              </span>
            </div>
          )}
          {view.dpeEtiquetteGes && (
            <div class="dpe-badge">
              <span class="dpe-badge__label">GES</span>
              <span class:list={['dpe-badge__value', `ges-${view.dpeEtiquetteGes.toLowerCase()}`]}>
                {view.dpeEtiquetteGes}
              </span>
            </div>
          )}
        </div>
      </section>
    )}

    {!view.isClosed && (
      <section class="annonce-single__contact">
        <h2>Intéressé par ce bien ?</h2>
        <div class="contact-info">
          {view.contactAAfficher && !expert && <p><strong>{view.contactAAfficher}</strong></p>}
          {view.telephoneAAfficher && (
            <a href={`tel:${view.telephoneAAfficher.replace(/\s/g, '')}`} class="btn btn--primary">
              Appeler : {view.telephoneAAfficher}
            </a>
          )}
          {view.emailAAfficher && (
            <a href={`mailto:${view.emailAAfficher}?subject=Annonce ${view.reference} - ${view.titre}`} class="btn btn--secondary">
              Envoyer un email
            </a>
          )}
        </div>
        <p class="contact-ref">Référence : {view.reference}</p>
      </section>
    )}

    {view.isClosed && (
      <section class="annonce-single__closed-cta">
        <h2>Cette annonce est clôturée</h2>
        <p>Consultez nos annonces disponibles ou contactez-nous pour un bien similaire.</p>
        <div class="closed-cta__buttons">
          <a href="/annonces/" class="btn btn--primary">Voir les annonces actuelles</a>
          <a href="/contact-immobiliere-pujol/" class="btn btn--secondary">Nous contacter</a>
        </div>
        <p class="contact-ref">Référence : {view.reference}</p>
      </section>
    )}

    {expert && <ExpertCard expert={expert} />}

    {view.isClosed && view.related && view.related.length > 0 && (
      <section class="annonce-single__related">
        <h2>Autres biens dans le {view.codePostal || 'secteur'}</h2>
        <ul class="related-links">
          {view.related.map(r => (
            <li>
              <a href={`/annonces/${r.slug}/`}>
                {r.type_annonce === 'V' ? 'Vente' : 'Location'} — {r.titre}
                {r.prix ? ` — ${new Intl.NumberFormat('fr-FR').format(r.prix)} €` : ''}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="annonce-single__nav">
      <a href="/annonces/">← Retour aux annonces</a>
      {view.type === 'L' && <a href="/annonces/locations/">Voir toutes les locations</a>}
      {view.type === 'V' && <a href="/annonces/ventes/">Voir toutes les ventes</a>}
    </nav>
  </article>
</BaseLayout>

<style>
  .annonce-single__closed-banner {
    background: #fef3c7;
    border-left: 4px solid #d97706;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    border-radius: 4px;
  }
  .annonce-single__closed-banner p { margin: 0; }
  .annonce-single__closed-banner a { margin-left: 0.5rem; }

  .annonce-single__closed-cta {
    background: #f3f4f6;
    padding: 1.5rem;
    border-radius: 8px;
    margin: 2rem 0;
    text-align: center;
  }
  .closed-cta__buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin: 1rem 0;
    flex-wrap: wrap;
  }

  .annonce-single__related { margin-top: 2.5rem; }
  .related-links {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.5rem 1rem;
  }
  .related-links li { margin: 0; }
  .related-links a { font-size: 0.9rem; line-height: 1.4; }
</style>

<script>
  document.querySelectorAll('.gallery__thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = (btn as HTMLElement).dataset.src;
      const mainPhoto = document.getElementById('main-photo') as HTMLImageElement;
      if (src && mainPhoto) mainPhoto.src = src;
    });
  });
</script>
