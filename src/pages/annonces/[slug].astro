---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchUbiflowAnnonces, formatPrice } from '../../lib/ubiflow';
import { findExpertByEmail } from '../../lib/experts';
import { getClosedAnnonce, formatClosedPrice, type ClosedAnnonce } from '../../lib/closed-annonces';
import { buildRealEstateListing } from '../../lib/schemas';
import AnnonceLive from '../../components/annonces/AnnonceLive.astro';
import AnnonceClosed from '../../components/annonces/AnnonceClosed.astro';

const { slug } = Astro.params;

// 1. Try active feed first.
const annonces = await fetchUbiflowAnnonces();
const active = slug ? annonces.find(a => a.slug === slug) : undefined;

// 2. Fallback: closed annonce loaded from the static assets layer.
let assets: { fetch: (req: Request) => Promise<Response> } | undefined;
try {
  const { env } = await import('cloudflare:workers');
  assets = (env as any)?.ASSETS;
} catch {
  // Not running under wrangler (e.g. astro dev) — fall back to plain fetch.
}
const closed = active ? null : await getClosedAnnonce(slug ?? '', assets, new URL(Astro.url.origin));

if (!active && !closed) {
  return Astro.redirect('/annonces/');
}

type View = {
  titre: string;
  description: string;
  type: 'V' | 'L' | string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  adresse?: string;
  codePostal?: string;
  ville?: string;
  quartier?: string;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | number;
  nbEtages?: string | number;
  typeChauffage?: string;
  cuisine?: string;
  dpeEtiquetteConso?: string;
  dpeEtiquetteGes?: string;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honorairesChargeAcquereur?: boolean;
  visiteVirtuelle?: string;
  dpeValeurConso?: string;
  dpeValeurGes?: string;
  isClosed: boolean;
  related: ClosedAnnonce['related'];
};

let view: View;
let expert: ReturnType<typeof findExpertByEmail> = null;

if (active) {
  expert = findExpertByEmail(active.emailAAfficher);
  view = {
    titre: active.titre,
    description: active.description,
    type: active.type,
    reference: active.reference,
    priceDisplay: formatPrice(active),
    photos: active.photos,
    adresse: active.adresse,
    codePostal: active.codePostal,
    ville: active.ville,
    quartier: (active as any).quartier,
    surface: (active as any).surface,
    nbPieces: (active as any).nbPieces,
    nbChambres: (active as any).nbChambres,
    nbSallesDeBain: (active as any).nbSallesDeBain,
    nbWC: (active as any).nbWC,
    etage: (active as any).etage,
    nbEtages: (active as any).nbEtages,
    typeChauffage: (active as any).typeChauffage,
    cuisine: (active as any).cuisine,
    dpeEtiquetteConso: (active as any).dpeEtiquetteConso,
    dpeEtiquetteGes: (active as any).dpeEtiquetteGes,
    dpeValeurConso: (active as any).dpeValeurConso,
    dpeValeurGes: (active as any).dpeValeurGes,
    loyer: (active as any).loyer,
    loyerCC: (active as any).loyerCC,
    charges: (active as any).charges,
    depotGarantie: (active as any).depotGarantie,
    prix: active.prix,
    honorairesChargeAcquereur: (active as any).honorairesChargeAcquereur,
    visiteVirtuelle: (active as any).visiteVirtuelle,
    isClosed: false,
    related: [],
  };
} else {
  const c = closed!;
  expert = findExpertByEmail(c.emailAAfficher);
  // Don't use c.seoTitle — it's almost always a truncated description, not a real title.
  const pieces = c.nbPieces ? ` ${c.nbPieces} pièce${c.nbPieces > 1 ? 's' : ''}` : '';
  const surface = c.surface ? ` de ${c.surface} m²` : '';
  const where = [c.ville, c.codePostal ? `(${c.codePostal})` : ''].filter(Boolean).join(' ');
  const action = c.typeAnnonce === 'V' ? 'à vendre' : 'à louer';
  const synthesizedTitle = `Appartement${pieces}${surface} ${action}${where ? ' à ' + where : ''}`.trim();
  view = {
    titre: synthesizedTitle,
    description: c.descriptif ?? '',
    type: c.typeAnnonce || 'V',
    reference: c.referenceAgence ?? c.slug,
    priceDisplay: formatClosedPrice(c),
    photos: c.photos ?? [],
    adresse: c.adresse,
    codePostal: c.codePostal,
    ville: c.ville,
    quartier: c.quartier,
    surface: c.surface ?? null,
    nbPieces: c.nbPieces ?? null,
    nbChambres: c.nbChambres ?? null,
    nbSallesDeBain: c.nbSallesBain ?? null,
    nbWC: c.nbWC ?? null,
    etage: c.etage,
    nbEtages: c.nbEtages,
    typeChauffage: c.typeChauffage,
    cuisine: c.cuisine,
    dpeEtiquetteConso: c.dpeNote,
    dpeEtiquetteGes: c.gesNote,
    loyerCC: c.loyerCC ?? null,
    charges: c.charges ?? null,
    prix: c.prix ?? null,
    isClosed: true,
    related: c.related ?? [],
  };
}

const pageTitle = `${view.titre} – Immobilière Pujol`;
const pageDescription = view.description ? view.description.substring(0, 160) : pageTitle;

const annonceUrl = new URL(`/annonces/${slug}/`, Astro.site).toString();
const listingSchema = buildRealEstateListing({
  titre: view.titre,
  description: view.description,
  slug: slug ?? '',
  type: view.type,
  prix: view.prix ?? null,
  loyerCC: view.loyerCC ?? null,
  surface: view.surface ?? null,
  nbPieces: view.nbPieces ?? null,
  adresse: view.adresse,
  codePostal: view.codePostal,
  ville: view.ville,
  photos: view.photos,
}, annonceUrl);
---

<BaseLayout title={pageTitle} description={pageDescription} schemas={[listingSchema]}>
  {active ? (
    <AnnonceLive
      view={view}
      contactName={active.contactAAfficher}
      contactPhone={active.telephoneAAfficher}
      contactEmail={active.emailAAfficher}
      expert={expert}
      pool={annonces}
      currentSlug={slug ?? ''}
    />
  ) : (
    <AnnonceClosed
      view={view}
      expert={expert}
      related={view.related}
      pool={annonces}
      currentSlug={slug ?? ''}
    />
  )}
</BaseLayout>
