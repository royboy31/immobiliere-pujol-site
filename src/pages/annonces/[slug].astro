---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAnnonceBySlug, getRelatedAnnonces, formatDbPrice } from '../../lib/db-annonces';
import { findExpertByEmail } from '../../lib/experts';
import { getClosedAnnonce, formatClosedPrice, type ClosedAnnonce } from '../../lib/closed-annonces';
import { buildRealEstateListing } from '../../lib/schemas';
import AnnonceLive from '../../components/annonces/AnnonceLive.astro';
import AnnonceClosed from '../../components/annonces/AnnonceClosed.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/annonces/');

const { env } = await import('cloudflare:workers');
const db = (env as any).DB as D1Database;

// Single D1 lookup — handles both active and closed annonces
const annonce = await getAnnonceBySlug(db, slug);

if (!annonce) {
  // Fallback: try loading from static assets (for annonces not yet seeded to D1)
  const { getClosedAnnonce } = await import('../../lib/closed-annonces');
  const assets = (env as any)?.ASSETS;
  const closed = await getClosedAnnonce(slug, assets, new URL(Astro.url.origin));
  if (!closed) return Astro.redirect('/annonces/');

  // Redirect will be removed once all annonces are seeded to D1
  // For now, render closed annonce from static assets with same template
}

const isClosed = annonce ? annonce.status === 'closed' : true;

// Build view model from D1 data
const expert = annonce ? findExpertByEmail(annonce.email_a_afficher) : null;

type View = {
  titre: string;
  description: string;
  type: string;
  reference: string;
  priceDisplay: string;
  photos: string[];
  adresse?: string | null;
  codePostal?: string | null;
  ville?: string | null;
  quartier?: string | null;
  surface?: number | null;
  nbPieces?: number | null;
  nbChambres?: number | null;
  nbSallesDeBain?: number | null;
  nbWC?: number | null;
  etage?: string | null;
  nbEtages?: string | null;
  typeChauffage?: string | null;
  dpeEtiquetteConso?: string | null;
  dpeEtiquetteGes?: string | null;
  dpeValeurConso?: string | null;
  dpeValeurGes?: string | null;
  loyer?: number | null;
  loyerCC?: number | null;
  charges?: number | null;
  depotGarantie?: number | null;
  prix?: number | null;
  honoraires?: string | null;
  honorairesChargeAcquereur?: boolean;
  visiteVirtuelle?: string;
  isClosed: boolean;
  related: { slug: string; title: string; prix: number | null; type: string; cp: string }[];
  contactAAfficher?: string | null;
  telephoneAAfficher?: string | null;
  emailAAfficher?: string | null;
};

let view: View;

if (annonce) {
  const related = isClosed && annonce.code_postal
    ? await getRelatedAnnonces(db, annonce.code_postal, slug)
    : [];

  let titre = annonce.titre;
  if (isClosed && !titre) {
    const pieces = annonce.nb_pieces ? ` ${annonce.nb_pieces} pièce${annonce.nb_pieces > 1 ? 's' : ''}` : '';
    const surface = annonce.surface ? ` de ${annonce.surface} m²` : '';
    const where = [annonce.ville, annonce.code_postal ? `(${annonce.code_postal})` : ''].filter(Boolean).join(' ');
    const action = annonce.type_annonce === 'V' ? 'à vendre' : 'à louer';
    titre = `Appartement${pieces}${surface} ${action}${where ? ' à ' + where : ''}`.trim();
  }

  view = {
    titre,
    description: annonce.descriptif || '',
    type: annonce.type_annonce || 'V',
    reference: annonce.ubiflow_reference || annonce.reference_agence || annonce.slug,
    priceDisplay: formatDbPrice(annonce),
    photos: annonce.photos,
    adresse: annonce.adresse,
    codePostal: annonce.code_postal,
    ville: annonce.ville,
    quartier: annonce.quartier,
    surface: annonce.surface,
    nbPieces: annonce.nb_pieces,
    nbChambres: annonce.nb_chambres,
    nbSallesDeBain: annonce.nb_salles_bain,
    nbWC: annonce.nb_wc,
    etage: annonce.etage,
    nbEtages: annonce.nb_etages,
    typeChauffage: annonce.type_chauffage,
    dpeEtiquetteConso: annonce.dpe_note,
    dpeEtiquetteGes: annonce.ges_note,
    dpeValeurConso: null,
    dpeValeurGes: null,
    loyer: annonce.loyer_ht,
    loyerCC: annonce.loyer_cc,
    charges: annonce.charges,
    depotGarantie: annonce.depot_garantie,
    prix: annonce.prix,
    honoraires: annonce.honoraires,
    honorairesChargeAcquereur: false,
    isClosed,
    related: related.map(r => ({
      slug: r.slug,
      title: r.titre,
      prix: r.prix,
      type: r.type_annonce,
      cp: r.code_postal,
    })),
    contactAAfficher: annonce.contact_a_afficher,
    telephoneAAfficher: annonce.telephone_a_afficher,
    emailAAfficher: annonce.email_a_afficher,
  };
} else {
  return Astro.redirect('/annonces/');
}

const pageTitle = `${view.titre} – Immobilière Pujol`;
const pageDescription = view.description ? view.description.substring(0, 160) : pageTitle;

const annonceUrl = new URL(`/annonces/${slug}/`, Astro.site).toString();
const listingSchema = buildRealEstateListing({
  titre: view.titre,
  description: view.description,
  slug: slug,
  type: view.type,
  prix: view.prix ?? null,
  loyerCC: view.loyerCC ?? null,
  surface: view.surface ?? null,
  nbPieces: view.nbPieces ?? null,
  adresse: view.adresse,
  codePostal: view.codePostal,
  ville: view.ville,
  photos: view.photos,
}, annonceUrl);
---

<BaseLayout title={pageTitle} description={pageDescription} schemas={[listingSchema]}>
  {!view.isClosed ? (
    <AnnonceLive
      view={view}
      contactName={view.contactAAfficher}
      contactPhone={view.telephoneAAfficher}
      contactEmail={view.emailAAfficher}
      expert={expert}
      pool={[]}
      currentSlug={slug ?? ''}
    />
  ) : (
    <AnnonceClosed
      view={view}
      expert={expert}
      related={view.related}
      pool={[]}
      currentSlug={slug ?? ''}
    />
  )}
</BaseLayout>
