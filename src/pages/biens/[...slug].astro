---
// Legacy /biens/... URL preservation. On live WP these are JS-driven filter
// pages that all redirect client-side to /annonces/{type}/ with a fragment
// like #nb_pieces=appartement-t2. We do a clean server-side 301 to the same
// annonces page (without the fragment — fragment-driven filtering can be
// added to the annonces page itself later).

export const prerender = false;

const { slug } = Astro.params;
const segs = (slug ?? '').split('/').filter(Boolean);
const action = segs[0] ?? '';

let target = '/annonces/';
if (action === 'louer' || action === 'loues') {
  target = '/annonces/locations/';
} else if (action === 'acheter' || action === 'vendre' || action === 'vendus') {
  target = '/annonces/ventes/';
}

return Astro.redirect(target, 301);
---
