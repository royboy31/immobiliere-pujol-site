---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminEnv, getAdminPath } from '../../lib/admin-auth';

const env = await getAdminEnv();
const adminPath = getAdminPath(env);
const next = Astro.url.searchParams.get('next') || `/${adminPath}/`;
const error = Astro.url.searchParams.get('err');
---

<AdminLayout title="Connexion" hideSidebar>
  <div style="max-width: 420px; margin: 6rem auto;">
    <h1 style="text-align:center; margin-bottom: 2rem;">Admin Immobilière Pujol</h1>
    <div class="card">
      {error && (
        <p style="background:#fee2e2; color:#991b1b; padding:.6rem .8rem; border-radius:6px; margin-bottom:1rem;">
          Identifiants incorrects
        </p>
      )}
      <form method="POST" action={`/api/${adminPath}/auth/login`}>
        <input type="hidden" name="next" value={next} />
        <label>
          Email
          <input type="email" name="email" required autocomplete="username" />
        </label>
        <label>
          Mot de passe
          <input type="password" name="password" required autocomplete="current-password" />
        </label>
        <button type="submit" class="btn btn--primary" style="width:100%; margin-top:.5rem;">
          Se connecter
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
