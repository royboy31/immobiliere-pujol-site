---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // Slugs that have a dedicated .astro page in this directory must be
  // excluded here, otherwise Astro builds two pages for the same route.
  // Defined inside getStaticPaths because Astro hoists this function into an
  // isolated scope at build time.
  const DEDICATED = new Set([
    'agence-immobiliere-pujol',
    'syndic-de-copropriete-a-marseille',
    'vendre',
  ]);
  const entries = await getCollection('serviceImmobilier');
  return entries
    .filter((entry) => !DEDICATED.has(entry.data.slug))
    .map((entry) => ({
      params: { slug: entry.data.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
// The body is pure HTML (scraped from WP); bypass markdown processing so
// 4-space-indented lines aren't rendered as code blocks.
const rawBody = (entry as any).body ?? '';
---

<BaseLayout
  title={entry.data.seoTitle || `${entry.data.title} – Immobilière Pujol`}
  description={entry.data.seoDescription || ''}
>
  <article class="service-landing">
    <section class="service-landing__hero">
      {entry.data.heroImage && (
        <img src={entry.data.heroImage} alt={entry.data.title} />
      )}
      <h1>{entry.data.title}</h1>
      {entry.data.subtitle && <p class="service-landing__subtitle">{entry.data.subtitle}</p>}
    </section>

    <section class="service-landing__content" set:html={rawBody}></section>

    <section class="service-landing__cta">
      {entry.data.ctaText && (
        <a href="#form" class="btn btn--primary">{entry.data.ctaText}</a>
      )}
    </section>

    <section class="service-landing__form" id="form">
      <!-- Form placeholder — will be connected in Gate 3 -->
    </section>
  </article>
</BaseLayout>
