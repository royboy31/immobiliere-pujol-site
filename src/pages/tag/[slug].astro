---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  // Collect all unique tags across articles
  const tagMap = new Map<string, typeof articles>();
  for (const article of articles) {
    const tags = article.data.tags || [];
    for (const tag of tags) {
      const tagSlug = tag.toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '');
      if (!tagMap.has(tagSlug)) {
        tagMap.set(tagSlug, []);
      }
      tagMap.get(tagSlug)!.push(article);
    }
  }

  return Array.from(tagMap.entries()).map(([slug, articles]) => ({
    params: { slug },
    props: {
      tag: articles[0]?.data.tags?.find((t: string) =>
        t.toLowerCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, '') === slug
      ) || slug,
      articles: articles.sort((a, b) =>
        new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
      ),
    },
  }));
}

interface Props {
  tag: string;
  articles: any[];
}

const { tag, articles } = Astro.props;
---

<BaseLayout
  title={`${tag} – Immobilière Pujol`}
  description={`Articles sur le thème : ${tag}`}
>
  <section class="blog-archive blog-archive--tag">
    <h1>{tag}</h1>
    <p class="blog-archive__count">{articles.length} article{articles.length > 1 ? 's' : ''}</p>

    <div class="blog-archive__grid">
      {articles.map((article) => (
        <article class="blog-card">
          {article.data.featuredImage && (
            <img src={article.data.featuredImage} alt={article.data.title} loading="lazy" />
          )}
          <h2>
            <a href={`/${article.data.slug}/`}>{article.data.title}</a>
          </h2>
          {article.data.excerpt && <p>{article.data.excerpt}</p>}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
