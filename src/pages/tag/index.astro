---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const slugify = (s: string): string =>
  s.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const articles = await getCollection('articles');

const tagMap = new Map<string, { name: string; count: number }>();
for (const a of articles) {
  for (const tag of (a.data.tags || []) as string[]) {
    const slug = slugify(tag);
    if (!tagMap.has(slug)) tagMap.set(slug, { name: tag, count: 0 });
    tagMap.get(slug)!.count++;
  }
}

const tags = [...tagMap.entries()]
  .map(([slug, { name, count }]) => ({ slug, name, count }))
  .sort((a, b) => a.name.localeCompare(b.name, 'fr'));
---

<BaseLayout
  title="Tags – Immobilière Pujol"
  description="Tous les tags du blog immobilier Marseille."
>
  <section class="blog-archive blog-archive--tag">
    <h1>Tags</h1>
    <p class="blog-archive__count">{tags.length} tag{tags.length > 1 ? 's' : ''}</p>

    <ul class="tag-list">
      {tags.map(t => (
        <li>
          <a href={`/tag/${t.slug}/`}>
            {t.name} <span>({t.count})</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style lang="scss">
  .tag-list {
    list-style: none;
    padding: 0;
    max-width: 800px;
    margin: 2rem auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;

    a {
      display: inline-block;
      padding: 0.5rem 1rem;
      border-radius: 20px;
      background: $color-bg-alt;
      color: $color-text;
      text-decoration: none;
      font-size: 0.9rem;
      transition: background 0.2s;
      &:hover { background: darken($color-bg-alt, 5%); }
    }

    span {
      color: $color-text-muted;
      font-size: 0.85em;
    }
  }
</style>
