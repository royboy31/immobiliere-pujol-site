---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const slugify = (s: string): string =>
  s
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services
    .filter((entry) => entry.data.slug && entry.data.slug !== 'services')
    .map((entry) => {
      const slug = entry.data.slug.replace(/^services\//, '');
      return {
        params: { slug },
        props: { entry },
      };
    });
}

const { entry } = Astro.props;
const slug = entry.data.slug.replace(/^services\//, '');
const pagePath = `/services/${slug}/`;

const title = entry.data.seoTitle || `${entry.data.title} – Immobilière Pujol`;
const description = entry.data.seoDescription || '';

const rawBody: string = (entry as any).body ?? '';

// Pull hero image from the legacy body (largest <picture> source) or fallback.
const heroImg =
  entry.data.featuredImage ||
  rawBody.match(/<picture class="hero__image[\s\S]*?<img[^>]*\ssrc="([^"]+)"/)?.[1] ||
  '/images/home/hero-bg.jpg';

// Optional sub-title shown under the hero h1 (only some pages have it).
const heroSub = rawBody.match(/<h4 class="hero__descr">([\s\S]*?)<\/h4>/)?.[1]?.trim() || '';

// Sidebar: parent service link + section number + sibling pages.
const parentMatch = rawBody.match(
  /<a class="contextual__parent"\s+href="([^"]+)"[\s\S]*?<h4>([\s\S]*?)<\/h4>/
);
const parentHref = parentMatch?.[1] || '/service-immobilier/agence-immobiliere-pujol/';
const parentLabel = parentMatch?.[2]?.trim() || 'Notre agence immobilière';

const sectionLabel =
  rawBody
    .match(/<aside class="contextual__nav">[\s\S]*?<ul>\s*<li>([\s\S]*?)<\/li>\s*<\/ul>/)?.[1]
    ?.trim() || '';

const siblingRegex = /<a class=\s*"\s*contextual__item"\s+href="([^"]+)">([\s\S]*?)<\/a>/g;
const siblings: { href: string; label: string }[] = [];
for (const m of rawBody.matchAll(siblingRegex)) {
  siblings.push({ href: m[1], label: m[2].replace(/\s+/g, ' ').trim() });
}

// Article body: pull only the inner content of <section class="contextual__section">.
let articleHtml =
  rawBody.match(/<section class="contextual__section"[^>]*>([\s\S]*?)<\/section>/)?.[1] || '';

// Strip the legacy duplicate H3 title — we already render the title in the hero.
articleHtml = articleHtml.replace(
  /^\s*<h3 class="contextual__title">[\s\S]*?<\/h3>/,
  ''
);

// If extraction failed (atypical entry), fall back to the raw body so nothing is lost.
const usingLegacyExtraction = articleHtml.length > 0;
let bodyHtml = usingLegacyExtraction ? articleHtml : rawBody;

// --- Legacy WP cleanup ---------------------------------------------------
// 1) Strip per-element inline styles that fight the article body typography
//    or hide bullets on list items (legacy WP editor exports include
//    "list-style-type: none" on wrapping <li>s, which then cascades to nested
//    <ul>s and erases their bullets).
bodyHtml = bodyHtml.replace(
  /\s+style="[^"]*\b(font-family|font-size|font-weight|color|list-style-type|line-height|text-align)\s*:[^"]*"/gi,
  ''
);
// 2) Empty <span>/<font> wrappers left behind by the strip above.
bodyHtml = bodyHtml.replace(/<span\s*>([\s\S]*?)<\/span>/gi, '$1');
bodyHtml = bodyHtml.replace(/<font[^>]*>([\s\S]*?)<\/font>/gi, '$1');

// 3) Strip Gravity Forms blocks that the WP editor sometimes embeds INSIDE the
//    contextual section. The page template already renders its own themed
//    contact form below the article, so the legacy gform is a duplicate.
bodyHtml = bodyHtml.replace(
  /<div[^>]*\bid=['"]gform_wrapper_\d+['"][^>]*>[\s\S]*?<\/form>\s*<\/div>\s*(?:<script[\s\S]*?<\/script>)?/gi,
  ''
);

// 5) Convert the legacy "Pour aller plus loin" related-article callout (rendered
//    in the WP editor as a single-cell bordered table) into a themed card.
bodyHtml = bodyHtml.replace(
  /<table\b[^>]*>\s*<tbody>\s*<tr>\s*<td[^>]*>([\s\S]*?Pour aller plus loin[\s\S]*?)<\/td>\s*<\/tr>\s*<\/tbody>\s*<\/table>/gi,
  (_match, inner) => {
    const cleanInner = inner
      .replace(/<p>\s*<b>\s*Pour aller plus loin[^<]*<\/b>\s*<\/p>/i, '')
      .trim();
    return `<aside class="svc-article-body__related"><span class="svc-article-body__related-label">Pour aller plus loin</span><div class="svc-article-body__related-body">${cleanInner}</div></aside>`;
  }
);

// 6) "Indicator list" — turn an intro paragraph ending with ":" followed by a
//    short-item bullet list into a numbered card grid (matches the values
//    cards on the about page). Only applied when items are short and parallel.
bodyHtml = bodyHtml.replace(
  /<p>([^<]+?:)<\/p>\s*<ul>([\s\S]*?)<\/ul>/gi,
  (match, intro, listBody) => {
    const items = [...listBody.matchAll(/<li[^>]*>([\s\S]*?)<\/li>/gi)].map(
      (m) => m[1].replace(/\s+/g, ' ').trim()
    );
    // Skip lists with nested structure, long items, or fewer than 3 entries.
    if (items.length < 3) return match;
    if (items.some((i) => /<\/?(ul|ol|p|h[1-6]|table|img)\b/i.test(i))) return match;
    if (items.some((i) => i.length > 140)) return match;
    const cards = items
      .map(
        (text, i) =>
          `<li class="svc-indicator-card"><span class="svc-indicator-card__num">${String(i + 1).padStart(2, '0')}</span><p class="svc-indicator-card__text">${text}</p></li>`
      )
      .join('');
    return `<p class="svc-indicators-intro">${intro}</p><ul class="svc-indicators">${cards}</ul>`;
  }
);

// 7) Convert the legacy "image button" CTA (a wp-image inside <h2><a>) into
//    a properly styled site-themed button. The label is inferred from the
//    image filename so each variant gets the right call to action.
bodyHtml = bodyHtml.replace(
  /<h2[^>]*>\s*<a\s+([^>]*?)href="([^"]+)"([^>]*)>\s*<img[^>]+\bwp-image-[^>]+\bsrc="([^"]+)"[^>]*>\s*<\/a>\s*<\/h2>/gi,
  (_match, before, href, after, imgSrc) => {
    const attrs = `${before} ${after}`;
    const targetMatch = attrs.match(/target="([^"]+)"/i);
    const target = targetMatch ? ` target="${targetMatch[1]}"` : '';
    const rel = /target="_blank"/i.test(attrs) ? ' rel="noopener"' : '';
    let label = 'Demander un devis';
    if (/devis-syndic|syndic/i.test(imgSrc)) label = 'Demander un devis syndic';
    else if (/gestion[-_]?locative|gestion/i.test(imgSrc)) label = 'Demander un devis gestion locative';
    else if (/vente|estimation/i.test(imgSrc)) label = 'Demander une estimation';
    return `<p class="svc-article-body__cta-wrap"><a class="svc-article-body__cta" href="${href}"${target}${rel}><span>${label}</span><svg width="18" height="14" viewBox="0 0 22 14" fill="none" aria-hidden="true"><path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>`;
  }
);

// Page-specific enhancement: render "Les valeurs de l'Immobilière Pujol"
// as a clean cards grid instead of the raw alternating <ul>/<p> markup.
type ValueCard = { num: string; title: string; description: string };
let valueCards: ValueCard[] = [];
let valuesHeading = '';

if (slug === 'pourquoi-nous-faisons-ce-metier') {
  // Split the body at the values heading and keep only the prose above it.
  const splitMatch = bodyHtml.match(/<h2[^>]*>\s*Les valeurs[\s\S]*$/i);
  if (splitMatch) {
    valuesHeading = "Les valeurs de l'Immobilière Pujol";
    bodyHtml = bodyHtml.slice(0, splitMatch.index).trimEnd();
    valueCards = [
      {
        num: '01',
        title: 'Authenticité',
        description:
          "Nous disons clairement ce que nous pensons à nos clients pour bâtir des relations franches, transparentes, amicales et durables.",
      },
      {
        num: '02',
        title: 'Engagement',
        description:
          "Quand nous nous engageons dans quelque chose, nous nous assurons que cela est fait correctement et avec rigueur.",
      },
      {
        num: '03',
        title: 'Énergie & enthousiasme',
        description:
          "Nous prenons du plaisir à faire notre métier et faisons le choix de le faire avec enthousiasme et dynamisme. Nous aimons faire la fête, rire, danser et travailler ensemble.",
      },
      {
        num: '04',
        title: 'Sécurité',
        description:
          "Nous partageons notre expérience et expertise avec nos clients et futurs clients afin de les aider à appréhender la réalité du marché et les sécuriser dans leurs choix et tous leurs projets immobiliers.",
      },
      {
        num: '05',
        title: 'Indépendance',
        description:
          "Nous avons fait le choix d'être indépendant afin d'être libre de développer des solutions innovantes et adaptées, de recruter des collaborateurs qui nous ressemblent et avec qui nous avons envie de grandir.",
      },
      {
        num: '06',
        title: 'Innovation',
        description:
          "Nous adoptons et testons sans cesse des nouvelles technologies afin de proposer un service toujours plus réactif, transparent et efficient.",
      },
    ];
  }
}

// Page-specific enhancement: render the team page with a clean lead block
// and a masonry-style photo gallery instead of a stack of <p><img></p>.
type TeamImage = { src: string; srcset: string; alt: string; portrait: boolean };
let teamLead = { headline: '', subline: '' };
let teamImages: TeamImage[] = [];

if (slug === 'la-team-pujol') {
  teamLead = {
    headline: 'À la rencontre de notre équipe',
    subline:
      "Nous aimons notre métier — mais nous aimons aussi partager de bons moments ensemble : rire, chanter, danser…",
  };

  const imgRegex = /<img\b[^>]*\bsrc="([^"]+)"[^>]*?(?:\bsrcset="([^"]*)")?[^>]*\balt="([^"]*)"[^>]*>/gi;
  for (const m of bodyHtml.matchAll(imgRegex)) {
    const src = m[1];
    const srcset = m[2] || '';
    const alt = m[3] || 'Équipe Immobilière Pujol';
    // Skip the hero image which is matched separately above.
    if (src === heroImg) continue;
    // Crude portrait detection from filename pattern (e.g. "-533x800").
    const dimMatch = src.match(/-(\d+)x(\d+)\./);
    const portrait = dimMatch ? Number(dimMatch[2]) > Number(dimMatch[1]) : false;
    teamImages.push({ src, srcset, alt, portrait });
  }

  // Once images are extracted, drop the entire article body — the lead and
  // gallery replace it.
  bodyHtml = '';
}

// Page-specific enhancement: turn the blog landing into an editorial layout
// with manifesto, category pillars, and the latest articles.
type BlogPillar = { label: string; slug: string; tagline: string; count: number };
type BlogArticle = { href: string; title: string; excerpt: string; image: string; date: string; category: string };
let blogManifesto = { quote: '', paragraphs: [] as string[], portrait: '' };
let blogPillars: BlogPillar[] = [];
let blogLatest: BlogArticle[] = [];

if (slug === 'le-blog-de-limmobiliere-pujol') {
  blogManifesto = {
    quote: "Un espace de liberté, d'avis et de coups de gueule.",
    paragraphs: [
      "Ce blog est un espace d'information et de communication pour nos clients et nos futurs clients.",
      "Nous le tenons depuis la création de la société, au gré du temps, des ressources et de nos envies.",
      "Notre équipe y participe : c'est aussi un terrain où l'on partage, où l'on argumente, où l'on râle parfois — et toujours avec franchise.",
    ],
    portrait:
      'https://pub-a37eed540afe4dc9b4479da74ba265e1.r2.dev/2019/02/PI-1348-170919-558x800.jpg',
  };

  const articles = await getCollection('articles');

  const pillarSpec = [
    {
      match: /marché immobilier à marseille/i,
      label: 'Le marché à Marseille',
      slug: 'le-marche-immobilier-a-marseille',
      tagline: 'Tendances, prix, mouvements — ce qui bouge sur le terrain.',
    },
    {
      match: /conseils pour investir/i,
      label: 'Conseils pour investir',
      slug: 'mes-conseils-pour-investir-en-immobilier-a-marseille',
      tagline: 'Nos retours de terrain pour acheter sans se tromper.',
    },
    {
      match: /prix\s*au\s*m2/i,
      label: 'Les prix au m²',
      slug: 'prix-immo-arrondissement',
      tagline: 'Arrondissement par arrondissement, le vrai pouls des prix.',
    },
    {
      match: /arrondissement|quartier|ma ville/i,
      label: 'Quartiers & arrondissements',
      slug: 'arrondissements-marseille',
      tagline: 'On vous emmène dans les rues de Marseille.',
    },
  ];

  blogPillars = pillarSpec.map((p) => ({
    label: p.label,
    slug: p.slug,
    tagline: p.tagline,
    count: articles.filter((a) =>
      (a.data.categories || []).some((c: string) => p.match.test(c))
    ).length,
  }));

  blogLatest = articles
    .filter((a) => a.data.featuredImage && a.data.date)
    .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''))
    .slice(0, 3)
    .map((a) => ({
      href: `/${a.data.slug}/`,
      title: a.data.title,
      excerpt: (a.data.excerpt || '').replace(/\s+/g, ' ').trim().slice(0, 160),
      image: a.data.featuredImage as string,
      date: a.data.date as string,
      category: (a.data.categories && a.data.categories[0]) || 'Le blog',
    }));

  bodyHtml = '';
}

// Page-specific enhancement: turn the client reviews page into a structured
// rating headline + platform cards + video testimonials.
type ReviewPlatform = {
  key: string;
  href: string;
  name: string;
  tagline: string;
  cta: string;
  external: boolean;
};
let reviewsHero = { rating: '', total: '', headline: '', subline: '' };
let reviewPlatforms: ReviewPlatform[] = [];
let reviewVideos: string[] = [];
let reviewsClosing = '';

if (
  slug === 'les-avis-clients-de-limmobiliere-pujol' ||
  slug === 'avis-clients-immobiliere-pujol-marseille'
) {
  reviewsHero = {
    rating: '4,7 / 5',
    total: '+ 2 000 avis Google vérifiés',
    headline: 'Vous nous recommandez. Nous le rendons bien.',
    subline:
      "Les avis de nos clients sont l'un des indicateurs les plus honnêtes de la qualité de service que nous délivrons — sur Google, Pages Jaunes, Opinion System, Immodvisor et YouTube.",
  };

  // Shared platforms across both review pages.
  const googleCard: ReviewPlatform = {
    key: 'google',
    href: 'https://www.google.fr/search?q=immobili%C3%A8re+pujol&cad=h',
    name: 'Google',
    tagline: "Les avis publiés par nos clients sur la fiche Google de l'agence.",
    cta: 'Voir sur Google',
    external: true,
  };
  const immodvisorCard: ReviewPlatform = {
    key: 'immodvisor',
    href: 'https://www.immodvisor.com/pro/immobiliere-pujol-marseille-13006-149.html',
    name: 'Immodvisor',
    tagline: 'La plateforme spécialisée des avis du secteur immobilier.',
    cta: 'Voir sur Immodvisor',
    external: true,
  };
  const youtubeCard: ReviewPlatform = {
    key: 'youtube',
    href: 'https://www.youtube.com/channel/UCqKIrOqKql-5A7sUsGuIphA',
    name: 'YouTube',
    tagline: 'Nos clients racontent leur expérience face caméra.',
    cta: 'Voir les vidéos',
    external: true,
  };
  const pagesJaunesCard: ReviewPlatform = {
    key: 'pagesjaunes',
    href: 'https://www.pagesjaunes.fr/pros/09570235',
    name: 'Pages Jaunes',
    tagline: 'Les avis déposés sur notre fiche Pages Jaunes.',
    cta: 'Voir sur Pages Jaunes',
    external: true,
  };

  if (slug === 'les-avis-clients-de-limmobiliere-pujol') {
    reviewPlatforms = [
      googleCard,
      {
        key: 'os-vente',
        href: 'http://avis-immobiliere-pujolvente.opinionsystem.fr/',
        name: 'Opinion System — Vente',
        tagline: 'Avis vérifiés des clients qui ont vendu un bien avec nous.',
        cta: 'Lire les avis vente',
        external: true,
      },
      {
        key: 'os-syndic',
        href: 'http://immobilere-pujol-syndic.opinionsystem.fr/',
        name: 'Opinion System — Syndic',
        tagline: 'Retours des copropriétés que nous accompagnons en syndic.',
        cta: 'Lire les avis syndic',
        external: true,
      },
      {
        key: 'os-gestion',
        href: 'http://avis-immobiliere-pujol-gestionlocative.opinionsystem.fr/',
        name: 'Opinion System — Gestion locative',
        tagline: 'Témoignages des propriétaires qui nous confient leur bien.',
        cta: 'Lire les avis gestion',
        external: true,
      },
      immodvisorCard,
      youtubeCard,
    ];
  } else {
    // avis-clients-immobiliere-pujol-marseille — uses Pages Jaunes + the
    // OpinionSystem certificate URLs.
    reviewPlatforms = [
      googleCard,
      pagesJaunesCard,
      {
        key: 'os-vente',
        href: 'https://www.opinionsystem.fr/fr-fr/certificate/4429',
        name: 'Opinion System — Vente',
        tagline: 'Certificat des avis vérifiés sur nos transactions de vente.',
        cta: 'Voir le certificat',
        external: true,
      },
      {
        key: 'os-syndic',
        href: 'https://www.opinionsystem.fr/fr-fr/certificate/4431',
        name: 'Opinion System — Syndic',
        tagline: 'Certificat des avis vérifiés sur notre service syndic.',
        cta: 'Voir le certificat',
        external: true,
      },
      {
        key: 'os-gestion',
        href: 'https://www.opinionsystem.fr/fr-fr/certificate/4430',
        name: 'Opinion System — Gestion locative',
        tagline: "Certificat des avis vérifiés sur notre service de gestion locative.",
        cta: 'Voir le certificat',
        external: true,
      },
      immodvisorCard,
      youtubeCard,
    ];
  }

  reviewVideos = [
    'https://www.youtube.com/embed/OuoZE8zdgzk',
    'https://www.youtube.com/embed/Bm1-qe2R3_c',
  ];

  reviewsClosing =
    "Nos clients partagent leur expérience et nous aident à nous améliorer au quotidien.";

  bodyHtml = '';
}

// Page-specific enhancement: render the "Contacter un conseiller en gestion
// locative" page as a side-by-side expert card (portrait left, contact details
// right) instead of a stack of centred legacy paragraphs.
type ContactExpert = {
  name: string;
  role: string;
  photo: string;
  pitch: string[];
  phone: string;
  phoneHref: string;
  email: string;
  qrSrc: string;
  qrCaption: string;
};
let contactExpert: ContactExpert | null = null;

if (slug === 'contacter-un-conseiller-en-gestion-locative') {
  contactExpert = {
    name: 'Gaëlle Lapert',
    role: 'Directrice commerciale Gestion Locative — Immobilière Pujol',
    photo: '/images/home/gaelle-pujol.png',
    pitch: [
      "Bonjour, vous souhaitez avoir des renseignements et obtenir une proposition personnalisée pour la gestion locative de vos biens à Marseille — que ce soit dans le neuf ou dans l'ancien, pour une location vide ou meublée, pour des bureaux ou des locaux commerciaux ?",
      "Contactez-moi, je répondrai avec plaisir à toutes vos questions.",
    ],
    phone: '06 08 87 20 05',
    phoneHref: 'tel:+33608872005',
    email: 'gaelle@immobiliere-pujol.fr',
    qrSrc: 'https://pub-a37eed540afe4dc9b4479da74ba265e1.r2.dev/2021/01/QR-CODES.jpg',
    qrCaption: 'Scannez ce QR code pour réserver un rendez-vous téléphonique avec Gaëlle.',
  };
  bodyHtml = '';
}

// Build the sidebar list: parent header, section label, then siblings + current page.
const sidebarItems = [
  ...siblings.map((s) => ({ ...s, current: false })),
  { href: pagePath, label: entry.data.title, current: true },
].sort((a, b) => a.label.localeCompare(b.label));

const formObjects = ['Location', 'Vente', 'Gestion locative', 'Achat', 'Syndic', 'Autre'];
---

<BaseLayout title={title} description={description}>
  {/* ============= HERO ============= */}
  <section class="svc-hero" style={`background-image: linear-gradient(rgba(15,25,42,.35), rgba(15,25,42,.45)), url('${heroImg}');`}>
    <div class="svc-hero__overlay"></div>

    <div class="svc-hero__inner">
      <h1>{entry.data.title}</h1>
      {heroSub && <p class="svc-hero__sub">{heroSub}</p>}
      <a class="svc-hero__cta" href="#form">{entry.data.ctaText || "Contacter l'agence"}</a>
    </div>
  </section>

  <div class="svc-page">

    {/* ============= TOC + ARTICLE ============= */}
    <section class="svc-toc-section">
      <div class="svc-toc-section__inner">

        <aside class="svc-toc">
          <a class="svc-toc__parent" href={parentHref}>
            <p class="svc-toc__title">{parentLabel}</p>
          </a>
          {sectionLabel && <p class="svc-toc__section-label">{sectionLabel}</p>}
          <ul class="svc-toc__list">
            {sidebarItems.map((it) => (
              <li>
                <a
                  class={`svc-toc__link${it.current ? ' is-active' : ''}`}
                  href={it.href}
                  aria-current={it.current ? 'page' : undefined}
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <div class="svc-content svc-content--article">
          {reviewPlatforms.length > 0 ? (
            <>
              <section class="svc-reviews-hero">
                <div class="svc-reviews-hero__badge">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 2 L14.94 8.46 L22 9.27 L16.5 13.97 L18.18 21 L12 17.27 L5.82 21 L7.5 13.97 L2 9.27 L9.06 8.46 Z" fill="currentColor" />
                  </svg>
                  <div>
                    <span class="svc-reviews-hero__rating">{reviewsHero.rating}</span>
                    <span class="svc-reviews-hero__total">{reviewsHero.total}</span>
                  </div>
                </div>
                <h2 class="svc-reviews-hero__headline">{reviewsHero.headline}</h2>
                <p class="svc-reviews-hero__subline">{reviewsHero.subline}</p>
              </section>

              <section class="svc-review-platforms" aria-labelledby="svc-review-platforms-title">
                <h2 class="svc-review-platforms__title" id="svc-review-platforms-title">
                  Où retrouver <b>nos avis</b>
                </h2>
                <ul class="svc-review-platforms__grid">
                  {reviewPlatforms.map((p) => (
                    <li class={`svc-platform-card svc-platform-card--${p.key}`}>
                      <a href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener' : undefined}>
                        <span class="svc-platform-card__logo" aria-hidden="true">
                          {p.key === 'google' && (
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09 0-.73.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                            </svg>
                          )}
                          {p.key.startsWith('os-') && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6" />
                              <path d="M9 12 L11 14 L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                            </svg>
                          )}
                          {p.key === 'immodvisor' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                              <path d="M3 11 L12 3 L21 11" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                              <path d="M5 10 V21 H19 V10" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                              <path d="M10 21 V14 H14 V21" stroke="currentColor" stroke-width="1.6" />
                            </svg>
                          )}
                          {p.key === 'youtube' && (
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                              <rect x="2" y="6" width="20" height="12" rx="3" fill="#FF0000" />
                              <path d="M10 9.5 L15 12 L10 14.5 Z" fill="#fff" />
                            </svg>
                          )}
                          {p.key === 'pagesjaunes' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                              <rect x="3" y="3" width="18" height="18" rx="3" fill="#FFCB05" />
                              <text x="12" y="16" text-anchor="middle" font-family="Helvetica, Arial, sans-serif" font-weight="700" font-size="11" fill="#000">PJ</text>
                            </svg>
                          )}
                        </span>
                        <h3 class="svc-platform-card__name">{p.name}</h3>
                        <p class="svc-platform-card__tagline">{p.tagline}</p>
                        <span class="svc-platform-card__cta">
                          {p.cta}
                          <svg width="18" height="12" viewBox="0 0 22 14" fill="none" aria-hidden="true">
                            <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>

              <section class="svc-review-videos" aria-labelledby="svc-review-videos-title">
                <h2 class="svc-review-videos__title" id="svc-review-videos-title">
                  Ils en parlent <b>face caméra</b>
                </h2>
                <ul class="svc-review-videos__grid">
                  {reviewVideos.map((src, i) => (
                    <li class="svc-review-video">
                      <div class="svc-review-video__frame">
                        <iframe
                          src={src}
                          title={`Témoignage client ${i + 1}`}
                          loading="lazy"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen
                        ></iframe>
                      </div>
                    </li>
                  ))}
                </ul>
              </section>

              <p class="svc-reviews-closing">
                <span aria-hidden="true">"</span>
                {reviewsClosing}
                <span aria-hidden="true">"</span>
              </p>
            </>
          ) : blogPillars.length > 0 ? (
            <>
              <section class="svc-blog-manifesto">
                <div class="svc-blog-manifesto__copy">
                  <p class="svc-blog-manifesto__quote">{blogManifesto.quote}</p>
                  {blogManifesto.paragraphs.map((p) => (
                    <p class="svc-blog-manifesto__para">{p}</p>
                  ))}
                </div>
                <figure class="svc-blog-manifesto__portrait">
                  <img src={blogManifesto.portrait} alt="L'équipe au travail" loading="lazy" decoding="async" />
                  <figcaption>L'équipe au travail.</figcaption>
                </figure>
              </section>

              <section class="svc-blog-pillars" aria-labelledby="svc-blog-pillars-title">
                <header class="svc-blog-pillars__head">
                  <h2 id="svc-blog-pillars-title">Les <b>4 univers</b> du blog</h2>
                  <p>Chaque catégorie suit un fil rouge — choisissez le vôtre.</p>
                </header>
                <ul class="svc-blog-pillars__grid">
                  {blogPillars.map((p, i) => (
                    <li class="svc-pillar-card">
                      <a href={`/categorie/${p.slug}/`}>
                        <span class="svc-pillar-card__num">{String(i + 1).padStart(2, '0')}</span>
                        <h3 class="svc-pillar-card__title">{p.label}</h3>
                        <p class="svc-pillar-card__tagline">{p.tagline}</p>
                        <span class="svc-pillar-card__count">
                          {p.count} {p.count > 1 ? 'articles' : 'article'}
                        </span>
                        <span class="svc-pillar-card__arrow" aria-hidden="true">
                          <svg width="22" height="14" viewBox="0 0 22 14" fill="none">
                            <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>

              {blogLatest.length > 0 && (
                <section class="svc-blog-latest" aria-labelledby="svc-blog-latest-title">
                  <header class="svc-blog-latest__head">
                    <h2 id="svc-blog-latest-title">Les <b>derniers articles</b></h2>
                    <a href="/blog-immobilier-marseille/" class="svc-blog-latest__all">
                      Voir tout le blog
                      <svg width="18" height="12" viewBox="0 0 22 14" fill="none" aria-hidden="true">
                        <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </a>
                  </header>
                  <ul class="svc-blog-latest__grid">
                    {blogLatest.map((a) => (
                      <li class="svc-post-card">
                        <a href={a.href}>
                          <div class="svc-post-card__media">
                            <img src={a.image} alt="" loading="lazy" decoding="async" />
                          </div>
                          <div class="svc-post-card__body">
                            <span class="svc-post-card__cat">{a.category}</span>
                            <h3 class="svc-post-card__title">{a.title}</h3>
                            {a.excerpt && <p class="svc-post-card__excerpt">{a.excerpt}…</p>}
                            <span class="svc-post-card__date">
                              {new Date(a.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                            </span>
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

            </>
          ) : teamImages.length > 0 ? (
            <>
              <header class="svc-team-lead">
                <h2 class="svc-team-lead__headline">{teamLead.headline}</h2>
                <p class="svc-team-lead__subline">{teamLead.subline}</p>
              </header>
              <div class="svc-team-gallery" data-lightbox-gallery>
                {teamImages.map((img, i) => (
                  <button
                    type="button"
                    class={`svc-team-gallery__item${img.portrait ? ' is-portrait' : ''}`}
                    data-lightbox-index={i}
                    aria-label={`Agrandir : ${img.alt}`}
                  >
                    <img
                      src={img.src}
                      srcset={img.srcset || undefined}
                      sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 33vw"
                      alt={img.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  </button>
                ))}
              </div>

              <div class="svc-lightbox" data-lightbox aria-hidden="true" role="dialog" aria-modal="true" aria-label="Galerie photo de l'équipe">
                <button type="button" class="svc-lightbox__close" data-lightbox-close aria-label="Fermer">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M3 3 L19 19 M19 3 L3 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </button>
                <button type="button" class="svc-lightbox__nav svc-lightbox__nav--prev" data-lightbox-prev aria-label="Image précédente">
                  <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
                    <path d="M16 4 L7 13 L16 22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                <button type="button" class="svc-lightbox__nav svc-lightbox__nav--next" data-lightbox-next aria-label="Image suivante">
                  <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
                    <path d="M10 4 L19 13 L10 22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                <figure class="svc-lightbox__stage">
                  <img data-lightbox-image alt="" />
                  <figcaption class="svc-lightbox__counter" data-lightbox-counter></figcaption>
                </figure>
              </div>

              <script is:inline define:vars={{ teamImages }}>
                (function () {
                  const root = document.querySelector('[data-lightbox]');
                  const gallery = document.querySelector('[data-lightbox-gallery]');
                  if (!root || !gallery) return;

                  const imgEl = root.querySelector('[data-lightbox-image]');
                  const counter = root.querySelector('[data-lightbox-counter]');
                  const closeBtn = root.querySelector('[data-lightbox-close]');
                  const prevBtn = root.querySelector('[data-lightbox-prev]');
                  const nextBtn = root.querySelector('[data-lightbox-next]');
                  const items = teamImages;

                  let current = 0;
                  let lastFocus = null;

                  function show(i) {
                    current = (i + items.length) % items.length;
                    const it = items[current];
                    imgEl.src = it.src;
                    if (it.srcset) imgEl.srcset = it.srcset; else imgEl.removeAttribute('srcset');
                    imgEl.alt = it.alt || '';
                    counter.textContent = (current + 1) + ' / ' + items.length;
                  }

                  function open(i) {
                    lastFocus = document.activeElement;
                    show(i);
                    root.classList.add('is-open');
                    root.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                    closeBtn.focus();
                    document.addEventListener('keydown', onKey);
                  }

                  function close() {
                    root.classList.remove('is-open');
                    root.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                    document.removeEventListener('keydown', onKey);
                    if (lastFocus && lastFocus.focus) lastFocus.focus();
                  }

                  function onKey(e) {
                    if (e.key === 'Escape') close();
                    else if (e.key === 'ArrowRight') show(current + 1);
                    else if (e.key === 'ArrowLeft') show(current - 1);
                  }

                  gallery.addEventListener('click', (e) => {
                    const btn = e.target.closest('[data-lightbox-index]');
                    if (!btn) return;
                    open(Number(btn.dataset.lightboxIndex) || 0);
                  });

                  closeBtn.addEventListener('click', close);
                  prevBtn.addEventListener('click', () => show(current - 1));
                  nextBtn.addEventListener('click', () => show(current + 1));

                  root.addEventListener('click', (e) => {
                    if (e.target === root) close();
                  });

                  // Touch swipe
                  let touchStartX = 0;
                  root.addEventListener('touchstart', (e) => {
                    touchStartX = e.changedTouches[0].clientX;
                  }, { passive: true });
                  root.addEventListener('touchend', (e) => {
                    const dx = e.changedTouches[0].clientX - touchStartX;
                    if (Math.abs(dx) > 50) show(current + (dx < 0 ? 1 : -1));
                  }, { passive: true });
                })();
              </script>
            </>
          ) : contactExpert ? (
            <section class="svc-expert" aria-labelledby="svc-expert-name">
              <div class="svc-expert__photo">
                <img src={contactExpert.photo} alt={contactExpert.name} loading="eager" />
              </div>
              <div class="svc-expert__body">
                <h2 class="svc-expert__name" id="svc-expert-name">{contactExpert.name}</h2>
                <p class="svc-expert__role">{contactExpert.role}</p>
                {contactExpert.pitch.map((p) => (
                  <p class="svc-expert__pitch">{p}</p>
                ))}
                <ul class="svc-expert__contact">
                  <li>
                    <span class="svc-expert__label">Téléphone</span>
                    <a class="svc-expert__value" href={contactExpert.phoneHref}>{contactExpert.phone}</a>
                  </li>
                  <li>
                    <span class="svc-expert__label">Email</span>
                    <a class="svc-expert__value" href={`mailto:${contactExpert.email}`}>{contactExpert.email}</a>
                  </li>
                </ul>
                <figure class="svc-expert__qr">
                  <img src={contactExpert.qrSrc} alt="QR code de prise de rendez-vous" loading="lazy" />
                  <figcaption>{contactExpert.qrCaption}</figcaption>
                </figure>
              </div>
            </section>
          ) : (
            <article class="svc-article-body" set:html={bodyHtml}></article>
          )}

          {valueCards.length > 0 && (
            <section class="svc-values" aria-labelledby="svc-values-title">
              <h2 class="svc-values__title" id="svc-values-title">
                Les valeurs de <b>l'Immobilière Pujol</b>
              </h2>
              <ul class="svc-values__grid">
                {valueCards.map((v) => (
                  <li class="svc-value-card">
                    <span class="svc-value-card__num">{v.num}</span>
                    <h3 class="svc-value-card__title">{v.title}</h3>
                    <p class="svc-value-card__desc">{v.description}</p>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>

      </div>
    </section>

    {/* ============= CONTACT FORM ============= */}
    <section class="svc-form-wrap" id="form">
      <form
        class="svc-form"
        method="post"
        action={`${pagePath}#gf_4`}
        enctype="multipart/form-data"
        novalidate
      >
        <h2>Prenez contact <b>avec nous</b></h2>
        <p class="svc-form__lead">Remplissez ce formulaire et nous prendrons contact avec vous dans les 24 heures</p>

        <div class="svc-form__grid">
          <label class="svc-field">
            <span>Prénom *</span>
            <input type="text" name="input_6.3" placeholder="Prénom" required />
          </label>

          <label class="svc-field">
            <span>Nom *</span>
            <input type="text" name="input_6.6" placeholder="Nom" required />
          </label>

          <label class="svc-field">
            <span>Email *</span>
            <input type="email" name="input_2" placeholder="Email" required />
          </label>

          <label class="svc-field">
            <span>Téléphone *</span>
            <input type="tel" name="input_4" placeholder="Téléphone" required />
          </label>

          <label class="svc-field svc-field--full">
            <span>Objet de votre demande *</span>
            <select name="input_10" required>
              {formObjects.map((o) => (
                <option value={o}>{o}</option>
              ))}
            </select>
          </label>

          <label class="svc-field svc-field--full">
            <span>Décrivez votre demande *</span>
            <textarea name="input_3" rows="6" placeholder="Décrivez votre demande" required></textarea>
          </label>
        </div>

        <label class="svc-form__agree">
          <input type="checkbox" name="input_9.1" value="J'accepte le traitement de mes données dans le cadre de ma demande" required />
          <span>J'accepte le traitement de mes données dans le cadre de ma demande *</span>
        </label>

        <p class="svc-form__legal">
          En soumettant ce formulaire, j'accepte que les informations collectées soient utilisées dans le cadre de ma demande et de la relation commerciale qui peut en découler. Pour connaître et exercer vos droits, notamment de retrait de votre consentement à l'utilisation des données collectées par ce formulaire, veuillez consulter notre <a href="/politique-de-confidentialite/">Politique de confidentialité</a>.
        </p>

        <div style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden" aria-hidden="true">
          <label>Company<input type="text" name="input_11" tabindex="-1" autocomplete="new-password" /></label>
        </div>
        <input type="hidden" name="gform_submit" value="4" />
        <input type="hidden" name="is_submit_4" value="1" />

        <button class="svc-form__submit" type="submit">
          <span>ENVOYER</span>
          <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
            <path d="M1 7 H20 M14 1 L20 7 L14 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </form>
    </section>

  </div>
</BaseLayout>
