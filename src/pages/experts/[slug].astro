---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchUbiflowAnnonces } from '../../lib/ubiflow';
import AnnonceCard from '../../components/annonces/AnnonceCard.astro';
import { getExpertType } from '../../lib/experts';

type ExpertData = {
  title: string;
  slug: string;
  fonction?: string;
  description?: string;
  photo?: string;
  email?: string;
  phone?: string;
  linkedin?: string;
  facebook?: string;
  instagram?: string;
};
const expertModules = import.meta.glob<ExpertData>(
  '../../content/experts/*.json',
  { eager: true, import: 'default' },
);
const allExperts = Object.values(expertModules);

const { slug } = Astro.params;
const expert = allExperts.find((e) => e.slug === slug);
if (!expert) return new Response('Not found', { status: 404 });

const expertEmail = (expert.email || '')
  .split('|')[0]
  .trim()
  .replace(/!+$/, '')
  .toLowerCase();
const displayName = expert.title.split('|').pop()?.split('–')[0]?.trim() || expert.title;
const nameParts = displayName.split(/\s+/);
const firstName = nameParts[0] || displayName;
const lastName = nameParts.slice(1).join(' ');

// Active annonces — full UbiflowAnnonce shape so we can reuse <AnnonceCard>.
let activeAnnonces: Awaited<ReturnType<typeof fetchUbiflowAnnonces>> = [];
try {
  const annonces = await fetchUbiflowAnnonces();
  activeAnnonces = annonces.filter((a) => {
    const em = (a.emailAAfficher || '').split('|')[0].trim().replace(/!+$/, '').toLowerCase();
    return expertEmail && em === expertEmail;
  });
} catch (e) {
  // Feed unavailable — continue with just the historical listings.
}

// Shared ASSETS binding for static data fetches
let _assets: { fetch: (req: Request) => Promise<Response> } | undefined;
try {
  const { env } = await import('cloudflare:workers');
  _assets = (env as any)?.ASSETS;
} catch {}

let historyTotalCount = 0;
let historyListings: Array<{
  slug: string; title: string; type: string; status: string;
  prix: number | null; surface: number | null; nbPieces: number | null;
  codePostal: string; ville: string; photo: string | null;
}> = [];
try {
  const base = new URL(`/_data/expert-listings/${slug}.json`, Astro.url.origin);
  const req = new Request(base.toString());
  const resp = _assets ? await _assets.fetch(req) : await fetch(base.toString());
  if (resp && resp.ok) {
    const payload = (await resp.json()) as any;
    historyTotalCount = payload.totalCount ?? (payload.listings?.length ?? 0);
    historyListings = payload.listings ?? [];
  }
} catch (e) {}

const activeSlugs = new Set(activeAnnonces.map((a) => a.slug));
const closedOnly = historyListings.filter((l) => !activeSlugs.has(l.slug));
const closedVisible = closedOnly.slice(0, 12);

const pageDesc = expert.description
  ? expert.description.replace(/<[^>]+>/g, ' ').replace(/&nbsp;|&[a-z]+;/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 160)
  : `Profil de ${displayName} chez Immobilière Pujol. Biens gérés, actuellement disponibles et historique.`;
const pageTitle = `${displayName} – Immobilière Pujol`;

type ReviewsPayload = {
  collaboratorId: number;
  certificateUrl: string | null;
  rating: {
    overall: number;
    count: number;
    criteres: { label: string; score: number }[];
  } | null;
  surveys: {
    id: number | null;
    date: string | null;
    clientName: string;
    property: string;
    comment: string;
    agencyResponse: string | null;
  }[];
  fetchedAt: string;
};

let reviewsPayload: ReviewsPayload | null = null;
try {
  const base = new URL(`/_data/reviews/${slug}.json`, Astro.url.origin);
  const req = new Request(base.toString());
  const resp = _assets ? await _assets.fetch(req) : await fetch(base.toString());
  if (resp && resp.ok) reviewsPayload = await resp.json();
} catch {}

const phoneClean = (expert.phone || '').replace(/\s/g, '');
const mailtoLink = expert.email ? `mailto:${expert.email}` : '';
const hasSocial = !!(expert.linkedin || expert.facebook || expert.instagram);
const expertType = getExpertType(expert);
---

<BaseLayout title={pageTitle} description={pageDesc} schemas={
  reviewsPayload?.rating && reviewsPayload.rating.count > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: displayName,
        jobTitle: expert.fonction || undefined,
        worksFor: { '@type': 'RealEstateAgent', name: 'Immobilière Pujol' },
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: reviewsPayload.rating.overall,
          bestRating: 10,
          ratingCount: reviewsPayload.rating.count,
        },
      }]
    : []
}>
  <article class={`expert-page expert-page--${expertType}`}>
    <a href="/experts/" class="annonce-back annonce-back--floating">
      <svg width="18" height="14" viewBox="0 0 22 14" fill="none">
        <path d="M21 7 H2 M8 1 L2 7 L8 13" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Retour aux experts
    </a>

    {/* 2-col body — title + description on the left, sticky info card on the right */}
    <section class="expert-body">
      <div class="expert-body__main">
        <header class="expert-body__title">
          <span class="expert-body__overline">Votre conseiller</span>
          <h1 class="expert-body__name">
            {firstName}{lastName && <> <b>{lastName}</b></>}
          </h1>
          {expert.fonction && (
            <span class="expert-body__role-pill">{expert.fonction}</span>
          )}
        </header>

        {expert.description ? (
          <>
            <h2 class="expert-body__heading">À propos de <b>{firstName}</b></h2>
            <div class="expert-bio-content" set:html={expert.description}></div>
          </>
        ) : (
          <p class="expert-body__empty">Pas de description disponible pour cet expert.</p>
        )}
      </div>

      <aside class="expert-body__side">
        <div class="expert-info-card">
          <div class="expert-info-card__photo-wrap">
            {expert.photo ? (
              <img src={expert.photo} alt={displayName} class="expert-info-card__photo" loading="eager" />
            ) : (
              <div class="expert-info-card__photo expert-info-card__photo--empty">{firstName.charAt(0)}</div>
            )}
          </div>

          <div class="expert-info-card__body">
            <h3 class="expert-info-card__name">
              {firstName}{lastName && <> <b>{lastName}</b></>}
            </h3>
            {expert.fonction && <p class="expert-info-card__role">{expert.fonction}</p>}

            <div class="expert-info-card__ctas">
              {expert.phone && (
                <a href={`tel:${phoneClean}`} class="btn-pill btn-pill--olive">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 4 L9 4 L11 9 L8 11 a12 12 0 0 0 5 5 L15 13 L20 15 L20 19 a1 1 0 0 1 -1 1 A16 16 0 0 1 4 5 a1 1 0 0 1 1 -1 z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round" />
                  </svg>
                  APPELER {expert.phone}
                </a>
              )}
              {expert.email && (
                <a href={mailtoLink} class="btn-pill btn-pill--ghost">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6" fill="none" />
                    <path d="M3 7 L12 13 L21 7" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  ENVOYER UN EMAIL
                </a>
              )}
            </div>

            {hasSocial && (
              <div class="expert-info-card__social">
                <span class="expert-info-card__social-label">Suivez {firstName}</span>
                <div class="expert-info-card__social-row">
                  {expert.linkedin && (
                    <a href={expert.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4 H8 V20 H4 z M14 9 a5 5 0 0 1 5 5 V20 H15 V14 a1 1 0 0 0 -2 0 V20 H9 V9 H13 V11 a3 3 0 0 1 3 -2 z M6 7 a2 2 0 1 0 0 -4 a2 2 0 0 0 0 4 z" /></svg>
                    </a>
                  )}
                  {expert.facebook && (
                    <a href={expert.facebook} target="_blank" rel="noopener" aria-label="Facebook">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 4 H17 V8 H14 a1 1 0 0 0 -1 1 V11 H17 L16 15 H13 V21 H9 V15 H7 V11 H9 V9 a5 5 0 0 1 5 -5 z" /></svg>
                    </a>
                  )}
                  {expert.instagram && (
                    <a href={expert.instagram} target="_blank" rel="noopener" aria-label="Instagram">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" /></svg>
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>

        {/* Quick stats card under the photo card */}
        {(activeAnnonces.length > 0 || historyTotalCount > 0) && (
          <div class="expert-quickstats">
            <div class="expert-quickstats__cell">
              <span class="expert-quickstats__num">{activeAnnonces.length}</span>
              <span class="expert-quickstats__lbl">Disponibles</span>
            </div>
            <div class="expert-quickstats__cell">
              <span class="expert-quickstats__num">{historyTotalCount}</span>
              <span class="expert-quickstats__lbl">Accompagnés</span>
            </div>
          </div>
        )}
      </aside>
    </section>

    {reviewsPayload?.rating && reviewsPayload.rating.count > 0 && (
      <section class="expert-reviews">
        <header class="expert-reviews__head">
          <span class="expert-reviews__overline">Avis vérifiés</span>
          <h2 class="expert-reviews__title">
            Ce que les clients de <b>{firstName}</b> en pensent
          </h2>
          <div class="expert-reviews__score">
            <span class="expert-reviews__num">{reviewsPayload.rating.overall.toFixed(1)}</span>
            <span class="expert-reviews__den">/ 10</span>
            <span class="expert-reviews__count">
              ({reviewsPayload.rating.count} avis vérifié{reviewsPayload.rating.count > 1 ? 's' : ''})
            </span>
          </div>
          {reviewsPayload.certificateUrl && (
            <a href={reviewsPayload.certificateUrl} target="_blank" rel="noopener" class="expert-reviews__certif">
              Voir le certificat OpinionSystem
            </a>
          )}
        </header>

        {reviewsPayload.rating.criteres.length > 0 && (
          <ul class="expert-reviews__criteres">
            {reviewsPayload.rating.criteres.map((c) => (
              <li>
                <span>{c.label}</span>
                <strong>{c.score.toFixed(1)} / 10</strong>
              </li>
            ))}
          </ul>
        )}

        {reviewsPayload.surveys.length > 0 && (
          <ul class="expert-reviews__list" id="expert-reviews-list">
            {reviewsPayload.surveys.map((r, i) => (
              <li class={`expert-review-card${i >= 6 ? ' expert-review-card--hidden' : ''}`}>
                <div class="expert-review-card__head">
                  <span class="expert-review-card__client">{r.clientName}</span>
                  {r.date && <time>{new Date(r.date).toLocaleDateString('fr-FR')}</time>}
                </div>
                {r.property && <p class="expert-review-card__prop">{r.property}</p>}
                <blockquote>{r.comment}</blockquote>
                {r.agencyResponse && (
                  <div class="expert-review-card__reply">
                    <span>Réponse de l'Immobilière Pujol :</span>
                    <p>{r.agencyResponse}</p>
                  </div>
                )}
              </li>
            ))}
          </ul>
        )}

        {reviewsPayload.surveys.length > 6 && (
          <button type="button" class="expert-reviews__more" id="expert-reviews-toggle">
            Voir les {reviewsPayload.surveys.length - 6} autres avis
          </button>
        )}
      </section>
    )}

    {activeAnnonces.length > 0 && (
      <section class="expert-listings expert-listings--active">
        <header class="expert-listings__head">
          <span class="expert-listings__overline">Disponible</span>
          <h2 class="expert-listings__title">
            Les biens en charge de <b>{firstName}</b>
          </h2>
          <p class="expert-listings__sub">{activeAnnonces.length} bien{activeAnnonces.length > 1 ? 's' : ''} actuellement à la vente ou à la location.</p>
        </header>
        <div class="annonces-grid">
          {activeAnnonces.map((a) => <AnnonceCard annonce={a} />)}
        </div>
      </section>
    )}

    {closedVisible.length > 0 && (
      <section class="expert-listings expert-listings--closed">
        <header class="expert-listings__head">
          <span class="expert-listings__overline">Historique</span>
          <h2 class="expert-listings__title">
            Les biens déjà <b>accompagnés</b>
          </h2>
          <p class="expert-listings__sub">
            {historyTotalCount} biens vendus ou loués grâce à {firstName}.
          </p>
        </header>
        <div class="expert-history-grid">
          {closedVisible.map((l) => (
            <a href={`/annonces/${l.slug}/`} class="expert-history-card">
              <div
                class="expert-history-card__photo"
                style={l.photo ? `background-image:url('${l.photo}')` : undefined}
              >
                <span class={`expert-history-card__tag ${l.type === 'V' ? 'is-vente' : 'is-location'}`}>
                  {l.type === 'V' ? 'Vendu' : 'Loué'}
                </span>
              </div>
              <div class="expert-history-card__body">
                <div class="expert-history-card__title">{l.title}</div>
                <div class="expert-history-card__meta">
                  {l.surface && <span>{l.surface} m²</span>}
                  {l.nbPieces && <span>T{l.nbPieces}</span>}
                  {l.codePostal && <span>{l.codePostal}</span>}
                </div>
                {l.prix && (
                  <div class={`expert-history-card__price ${l.type === 'L' ? 'is-location' : ''}`}>
                    {new Intl.NumberFormat('fr-FR').format(l.prix)} €{l.type === 'L' ? '/mois' : ''}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
        {historyTotalCount > closedVisible.length && (
          <p class="expert-listings__more">
            … et {historyTotalCount - closedVisible.length} autres biens accompagnés par {firstName}.
          </p>
        )}
      </section>
    )}

    {activeAnnonces.length === 0 && closedOnly.length === 0 && (
      <section class="expert-listings expert-listings--empty">
        <p>Aucun bien n'est actuellement associé à ce profil.</p>
      </section>
    )}

    <section class="expert-final-cta">
      <h2 class="expert-final-cta__title">
        Un projet en tête ? <br />
        <b>Parlons-en avec {firstName}.</b>
      </h2>
      <div class="expert-final-cta__row">
        {expert.phone && (
          <a href={`tel:${phoneClean}`} class="btn-pill btn-pill--olive">
            APPELER {expert.phone}
          </a>
        )}
        {expert.email && (
          <a href={mailtoLink} class="btn-pill btn-pill--ghost">
            ENVOYER UN EMAIL
          </a>
        )}
      </div>
    </section>
  </article>

  <script>
    const btn = document.getElementById('expert-reviews-toggle');
    if (btn) {
      btn.addEventListener('click', () => {
        const hidden = document.querySelectorAll('.expert-review-card--hidden');
        hidden.forEach((el) => el.classList.remove('expert-review-card--hidden'));
        btn.remove();
      });
    }
  </script>

  <style>
    .expert-reviews {
      max-width: 900px;
      margin: 3rem auto;
      padding: 0 1rem;
    }
    .expert-reviews__head {
      margin-bottom: 2rem;
    }
    .expert-reviews__overline {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-olive, #6b7c3a);
      margin-bottom: 0.5rem;
    }
    .expert-reviews__title {
      font-size: 1.5rem;
      font-weight: 400;
      margin: 0 0 1rem;
    }
    .expert-reviews__title b {
      font-weight: 700;
    }
    .expert-reviews__score {
      display: flex;
      align-items: baseline;
      gap: 0.3rem;
      margin-bottom: 0.75rem;
    }
    .expert-reviews__num {
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1;
      color: var(--color-olive, #6b7c3a);
    }
    .expert-reviews__den {
      font-size: 1rem;
      color: var(--color-muted, #888);
    }
    .expert-reviews__count {
      font-size: 0.875rem;
      color: var(--color-muted, #888);
      margin-left: 0.5rem;
    }
    .expert-reviews__certif {
      display: inline-block;
      font-size: 0.8rem;
      color: var(--color-olive, #6b7c3a);
      text-decoration: underline;
    }
    .expert-reviews__criteres {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.75rem;
    }
    .expert-reviews__criteres li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--color-border, #e5e5e5);
      font-size: 0.9rem;
    }
    .expert-reviews__criteres li strong {
      white-space: nowrap;
      color: var(--color-olive, #6b7c3a);
    }
    .expert-reviews__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .expert-review-card {
      border: 1px solid var(--color-border, #e5e5e5);
      border-radius: 8px;
      padding: 1.25rem;
    }
    .expert-review-card--hidden {
      display: none;
    }
    .expert-review-card__head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }
    .expert-review-card__client {
      font-weight: 600;
      font-size: 0.95rem;
    }
    .expert-review-card__head time {
      font-size: 0.8rem;
      color: var(--color-muted, #888);
    }
    .expert-review-card__prop {
      font-size: 0.8rem;
      color: var(--color-muted, #888);
      margin: 0 0 0.5rem;
    }
    .expert-review-card blockquote {
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .expert-review-card__reply {
      margin-top: 0.75rem;
      padding: 0.75rem;
      background: var(--color-bg-subtle, #f8f8f6);
      border-radius: 6px;
      font-size: 0.85rem;
    }
    .expert-review-card__reply span {
      display: block;
      font-weight: 600;
      margin-bottom: 0.3rem;
      font-size: 0.8rem;
    }
    .expert-review-card__reply p {
      margin: 0;
    }
    .expert-reviews__more {
      display: block;
      margin: 1.5rem auto 0;
      padding: 0.6rem 1.5rem;
      background: var(--color-olive, #6b7c3a);
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 600;
    }
    .expert-reviews__more:hover {
      opacity: 0.9;
    }
  </style>
</BaseLayout>
