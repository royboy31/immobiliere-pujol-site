---
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { buildRealEstateAgent, autoBreadcrumb } from '../lib/schemas';
import '../styles/theme.scss';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  /** Page-specific JSON-LD schemas (Article, WebSite, RealEstateListing, etc.). */
  schemas?: any[];
  /** Disable the auto-generated BreadcrumbList schema. */
  breadcrumb?: boolean;
}

const {
  title,
  description = "Gestion locative, syndic de copropriété, vente de biens immobilier à Marseille. Immobilière Pujol.",
  ogImage = "/images/og-default.jpg",
  canonical,
  noindex = false,
  schemas: pageSchemas = [],
  breadcrumb = true,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site);

// STAGING: block all indexing until go-live.
// Set ALLOW_INDEXING=true in Cloudflare env vars when ready for production.
const shouldNoindex = noindex || !import.meta.env.ALLOW_INDEXING;

// GTM & analytics: only fire in production (when we allow indexing).
// Staging must never pollute live stats.
// GTM_ID can be overridden per environment if needed.
const gtmId = import.meta.env.GTM_ID || 'GTM-WNFF3V';
const loadAnalytics = !shouldNoindex;

// Always emit the enriched RealEstateAgent on every page. Pages can add their
// own schemas (Article, WebSite, RealEstateListing, BreadcrumbList) via
// the `schemas` prop. An automatic BreadcrumbList is generated from the URL
// unless `breadcrumb={false}` or the page already provides one.
const breadcrumbSchema = breadcrumb
  ? autoBreadcrumb(Astro.url.pathname, title.split('–')[0].trim())
  : null;

const allSchemas: any[] = [buildRealEstateAgent()];
if (breadcrumbSchema) allSchemas.push(breadcrumbSchema);
for (const s of pageSchemas) {
  if (s) allSchemas.push(s);
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&family=Sacramento&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta name="robots" content={shouldNoindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Immobilière Pujol" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@stephanepujol" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {loadAnalytics ? (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','${gtmId}');`} />
    ) : (
      <!-- Analytics disabled (staging / noindex). Enable by setting ALLOW_INDEXING in env. -->
    )}

    <!-- Schema.org JSON-LD -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    {loadAnalytics && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmId}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
